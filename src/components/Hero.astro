---
/**
 * Hero principal de la página de inicio.
 *
 * Renderiza el título, subtítulo con términos auto-enlazados (ITSOEH, TICs)
 * y el canvas 3D del modelo institucional. Los términos definidos en
 * `linkedTerms` se reemplazan por `<a>` automáticamente en el subtítulo.
 *
 * @prop lang — Idioma de la página para resolver traducciones
 */
import Model3DCanvas from './Model3DCanvas.astro';
import type { UiLanguage } from '../i18n/config';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: UiLanguage;
}

const { lang } = Astro.props;
const th = useTranslations(lang, 'home');
const subtitle = th('hero.subtitle');
const linkedTerms: Record<string, string> = {
  ITSOEH: 'https://es.wikipedia.org/wiki/Instituto_Tecnol%C3%B3gico_Superior_del_Occidente_del_Estado_de_Hidalgo',
  TICs: 'https://es.wikipedia.org/wiki/Tecnolog%C3%ADas_de_la_informaci%C3%B3n_y_la_comunicaci%C3%B3n'
};
const subtitleParts = subtitle.split(/(ITSOEH|TICs)/g);
---

<section class="min-h-screen flex flex-col lg:flex-row items-center relative overflow-hidden bg-apple-bg" id="hero">
  <div class="flex-1 px-5 sm:px-8 lg:px-[8vw] z-10 max-w-full lg:max-w-[800px] pt-[96px] sm:pt-[108px]">
    <h1 class="max-w-[13ch] text-balance text-[clamp(2.4rem,11vw,5.4rem)] font-black leading-[1.05] tracking-[-0.04em] mb-6 font-sans text-apple-text">
      {th('hero.title')}
    </h1>

    <p class="text-[clamp(1.05rem,4.8vw,1.55rem)] text-apple-muted font-medium leading-[1.4] mb-9 max-w-[650px] font-sans tracking-tight">
      {subtitleParts.map((part) =>
        linkedTerms[part] ? (
          <a
            href={linkedTerms[part]}
            target="_blank"
            rel="noopener noreferrer"
            class="hero-its-link"
          >
            {part}
          </a>
        ) : (
          part
        )
      )}
    </p>

    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4 flex-wrap">
      <a href={`/${lang}/formacion`} class="inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 bg-apple-blue text-white rounded-full text-[1rem] font-semibold transition-all duration-300 hover:bg-apple-blue-hover hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]">
        {th('hero.ctaPrimary')}
      </a>
      <a href={`/${lang}/formacion#plan-estudios`} class="inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 border border-apple-blue text-apple-blue rounded-full text-[1rem] font-semibold transition-all duration-300 hover:bg-apple-blue/5 hover:scale-[1.02]">
        {th('hero.ctaSecondary')}
      </a>
    </div>
  </div>

  <Model3DCanvas />
</section>
