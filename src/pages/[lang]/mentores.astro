---
import Layout from '../../layouts/Layout.astro';
import type { UiLanguage } from '../../i18n/config';
import { languages } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const t = useTranslations(lang, 'mentors');
const tc = useTranslations(lang, 'common');

const facultyCards = ['software', 'networks', 'data'] as const;
const clubs = ['robotics', 'iot', 'developers', 'entrepreneurs'] as const;
const creditCards = ['web', 'content', 'review', 'identity'] as const;
---

<Layout lang={lang} title={tc('nav.mentors')}>
  <main class="bg-white min-h-screen pt-32 pb-24 text-apple-text overflow-x-hidden">
    <section class="max-w-[980px] mx-auto px-5 sm:px-8 mb-20 text-center">
      <h1 class="text-[clamp(3rem,6vw,5rem)] font-black tracking-tight leading-[1] mb-6">{t('community.hero.title')}</h1>
      <p class="text-[1.15rem] md:text-[1.35rem] text-apple-muted font-medium leading-relaxed max-w-[860px] mx-auto">
        {t('community.hero.subtitle')}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#clubes"
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-blue text-white text-[1rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]"
        >
          {t('community.hero.primary')}
        </a>
        <a
          href="#equipo"
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-white border border-black/10 text-apple-text text-[1rem] font-semibold rounded-full hover:bg-black/[0.03] transition-colors"
        >
          {t('community.hero.secondary')}
        </a>
      </div>
    </section>

    <section id="equipo" class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-black/5 pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('community.coordination.title')}</h2>
      <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[920px]">{t('community.coordination.subtitle')}</p>

      <article class="mt-8 rounded-[2rem] border border-black/5 bg-gradient-to-b from-[#F5F5F7] to-[#EEF5FF] p-7 md:p-10 shadow-sm">
        <div class="grid grid-cols-1 lg:grid-cols-[110px_1fr] gap-6 items-start">
          <div class="w-[88px] h-[88px] rounded-2xl bg-white border border-black/10 inline-flex items-center justify-center text-[1.6rem] font-black tracking-tight text-apple-blue shadow-sm">
            JC
          </div>
          <div>
            <h3 class="text-[1.35rem] font-bold tracking-tight">{t('community.coordination.name')}</h3>
            <p class="mt-2 text-[1rem] text-apple-muted font-semibold leading-relaxed">{t('community.coordination.role')}</p>
            <p class="mt-4 text-[0.98rem] text-apple-muted font-medium leading-relaxed max-w-[860px]">{t('community.coordination.body')}</p>

            <div class="mt-6 flex flex-col sm:flex-row sm:flex-wrap gap-2.5 text-[0.93rem]">
              <a href="mailto:tics@itsoeh.edu.mx" class="inline-flex items-center px-4 py-2 rounded-full border border-black/10 bg-white font-semibold text-apple-text hover:text-apple-blue transition-colors">
                {t('community.coordination.email')}
              </a>
              <a href="tel:+527387354000" class="inline-flex items-center px-4 py-2 rounded-full border border-black/10 bg-white font-semibold text-apple-text hover:text-apple-blue transition-colors">
                {t('community.coordination.phone')}
              </a>
            </div>

            <div class="mt-6">
              <a href={`/${lang}/contacto`} class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
                {t('community.coordination.cta')} <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-black/5 pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('community.faculty.title')}</h2>
      <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[930px]">{t('community.faculty.subtitle')}</p>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-5">
        {facultyCards.map((card) => (
          <article class="rounded-2xl border border-black/5 bg-[#F5F5F7] p-6">
            <p class="text-[0.72rem] uppercase tracking-[0.16em] font-semibold text-apple-muted">{t(`community.faculty.cards.${card}.name`)}</p>
            <h3 class="mt-3 text-[1.05rem] font-bold leading-tight">{t(`community.faculty.cards.${card}.area`)}</h3>
            <p class="mt-3 text-[0.94rem] text-apple-muted font-medium leading-relaxed">{t(`community.faculty.cards.${card}.line`)}</p>
          </article>
        ))}
      </div>

      <article class="mt-6 rounded-2xl border border-dashed border-black/15 bg-white p-6">
        <h3 class="text-[1rem] font-bold tracking-tight">{t('community.faculty.updatingTitle')}</h3>
        <p class="mt-2 text-[0.95rem] text-apple-muted font-medium leading-relaxed">{t('community.faculty.updatingBody')}</p>
      </article>
    </section>

    <section id="clubes" class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-black/5 pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('community.clubs.title')}</h2>
      <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[930px]">{t('community.clubs.subtitle')}</p>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        {clubs.map((club) => {
          const link = t(`community.clubs.cards.${club}.url`);
          const hasExternalLink = /^https?:\/\//.test(link);

          return (
            <article class="rounded-2xl border border-black/5 bg-[#F5F5F7] p-6 shadow-sm">
              <h3 class="text-[1.08rem] font-bold">{t(`community.clubs.cards.${club}.title`)}</h3>
              <p class="mt-3 text-[0.95rem] text-apple-muted font-medium leading-relaxed">{t(`community.clubs.cards.${club}.description`)}</p>

              {hasExternalLink && (
                <div class="mt-6">
                  <a
                    href={link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4"
                  >
                    {t(`community.clubs.cards.${club}.cta`)} <span aria-hidden="true">&rarr;</span>
                  </a>
                </div>
              )}
            </article>
          );
        })}
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-black/5 pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('community.leadership.title')}</h2>
      <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[930px]">{t('community.leadership.subtitle')}</p>

      <div class="mt-8 grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6 items-stretch">
        <article class="rounded-2xl border border-black/5 bg-[#F5F5F7] p-6 md:p-7">
          <h3 class="text-[1.18rem] font-bold tracking-tight">{t('community.leadership.jose.name')}</h3>
          <p class="mt-2 text-[0.97rem] text-apple-muted font-semibold">{t('community.leadership.jose.role')}</p>
          <p class="mt-4 text-[0.95rem] text-apple-muted font-medium leading-relaxed">{t('community.leadership.jose.description')}</p>

          <div class="mt-5 flex flex-wrap gap-2">
            {['tag1', 'tag2', 'tag3', 'tag4'].map((tag) => (
              <span class="px-3 py-1 bg-white text-[0.8rem] font-semibold rounded-full border border-black/10 text-apple-text">
                {t(`community.leadership.jose.${tag}`)}
              </span>
            ))}
          </div>

          <div class="mt-6">
            <a href={`/${lang}/mentores/jose-manuel`} class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
              {t('community.leadership.jose.profile')} <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </article>

        <article class="rounded-2xl border border-dashed border-black/15 bg-white p-6 flex flex-col justify-center">
          <h3 class="text-[1rem] font-bold tracking-tight">{t('community.leadership.growingTitle')}</h3>
          <p class="mt-3 text-[0.92rem] text-apple-muted font-medium leading-relaxed">
            {t('community.leadership.growingBody')}
          </p>
        </article>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-black/5 pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('community.credits.title')}</h2>
      <p class="mt-4 text-[1.03rem] text-apple-muted font-medium leading-relaxed max-w-[940px]">{t('community.credits.body')}</p>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5">
        {creditCards.map((card) => (
          <article class="rounded-2xl border border-black/5 bg-[#F5F5F7] p-6">
            <p class="text-[0.72rem] uppercase tracking-[0.16em] font-semibold text-apple-muted">{t(`community.credits.cards.${card}.title`)}</p>
            <p class="mt-3 text-[0.98rem] font-semibold leading-relaxed text-apple-text">{t(`community.credits.cards.${card}.value`)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-[840px] mx-auto px-5 sm:px-8 text-center border-t border-black/5 pt-14 md:pt-20">
      <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-6">{t('community.cta.title')}</h2>
      <p class="text-[1.05rem] text-apple-muted font-medium leading-relaxed max-w-[760px] mx-auto mb-10">{t('community.cta.subtitle')}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`/${lang}/unirse`}
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-blue text-white text-[1rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]"
        >
          {t('community.cta.primary')}
        </a>
        <a
          href={`/${lang}/proyectos`}
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-white border border-black/10 text-apple-text text-[1rem] font-semibold rounded-full hover:bg-black/[0.03] transition-colors"
        >
          {t('community.cta.secondary')}
        </a>
      </div>
    </section>
  </main>
</Layout>
