---
/**
 * Página de Contacto.
 *
 * Arquitectura e Intención:
 * - Separa las intenciones del usuario en dos bloques visuales distintos:
 *   1. "Vías rápidas": WhatsApp y Correo (para aspirantes que buscan respuesta inmediata).
 *   2. "Vías institucionales": Redes sociales y mapa físico.
 * - El iframe de Google Maps tiene su atributo `title` traducido dinámicamente
 *   para accesibilidad (WCAG).
 * - Utiliza variables de `src/data/siteConfig.ts` para no tener que 
 *   actualizar teléfonos en múltiples archivos.
 */
import Layout from '../../layouts/Layout.astro';
import type { UiLanguage } from '../../i18n/config';
import { languages } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const t = useTranslations(lang, 'contact');
const tc = useTranslations(lang, 'common');

const phoneUrl = t('values.phoneUrl');
const whatsappUrl = t('values.whatsappUrl');
const emailUrl = t('values.emailUrl');
const instagramUrl = t('values.instagramUrl');
const facebookUrl = t('values.facebookUrl');
const tiktokUrl = t('values.tiktokUrl');
const githubUrl = t('values.githubUrl');
const admissionUrl = `/${lang}/unirse#admision-2026`;
const projectsUrl = `/${lang}/proyectos`;

const mapEmbedSrc = 'https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d2225.737312900873!2d-99.22126109580296!3d20.20515199712743!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e1!3m2!1ses-419!2smx!4v1777439045268!5m2!1ses-419!2smx';
---

<Layout lang={lang} title={tc('nav.contact')}>
  <main class="bg-apple-surface min-h-screen pt-32 pb-24 text-apple-text overflow-x-hidden">
    <section class="max-w-[980px] mx-auto px-5 sm:px-8 mb-20 text-center">
      <h1 class="text-[clamp(3rem,6vw,5rem)] font-black tracking-tight leading-[1] mb-6">{t('hero.title')}</h1>
      <p class="text-[1.15rem] md:text-[1.35rem] text-apple-muted font-medium leading-relaxed max-w-[860px] mx-auto">
        {t('hero.subtitle')}
      </p>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24">
      <div class="rounded-[2.5rem] border border-apple-border bg-apple-surface-alt p-8 md:p-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
          <article class="rounded-3xl border border-apple-border bg-apple-surface p-8 shadow-sm">
            <div class="space-y-5">
              <div>
                <p class="text-[0.74rem] font-semibold uppercase tracking-[0.18em] text-apple-muted mb-2">{t('labels.institution')}</p>
                <p class="text-[1.08rem] font-semibold text-apple-text leading-relaxed">{t('values.institutionLine1')}</p>
                <p class="text-[1.08rem] font-semibold text-apple-text leading-relaxed">{t('values.institutionLine2')}</p>
              </div>
              <div>
                <p class="text-[0.74rem] font-semibold uppercase tracking-[0.18em] text-apple-muted mb-2">{t('labels.location')}</p>
                <p class="text-[1rem] text-apple-muted font-medium leading-relaxed">{t('values.location')}</p>
              </div>
              <div>
                <p class="text-[0.74rem] font-semibold uppercase tracking-[0.18em] text-apple-muted mb-2">{t('labels.phone')}</p>
                <a href={phoneUrl} class="text-[1rem] font-semibold text-apple-text hover:text-apple-blue transition-colors">{t('values.phone')}</a>
              </div>
              <div>
                <p class="text-[0.74rem] font-semibold uppercase tracking-[0.18em] text-apple-muted mb-2">{t('labels.whatsapp')}</p>
                <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="text-[1rem] font-semibold text-apple-text hover:text-apple-blue transition-colors">{t('values.whatsapp')}</a>
              </div>
              <div>
                <p class="text-[0.74rem] font-semibold uppercase tracking-[0.18em] text-apple-muted mb-2">{t('labels.email')}</p>
                <a href={emailUrl} class="text-[1rem] font-semibold text-apple-text hover:text-apple-blue transition-colors">{t('values.email')}</a>
              </div>
            </div>

            <div class="mt-8 flex flex-col sm:flex-row sm:flex-wrap gap-3">
              <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex w-full sm:w-auto items-center justify-center px-5 py-3 bg-apple-blue text-white rounded-full text-[0.95rem] font-semibold hover:bg-apple-blue-hover transition-colors">
                {t('actions.whatsapp')}
              </a>
              <a href={emailUrl} class="inline-flex w-full sm:w-auto items-center justify-center px-5 py-3 bg-apple-surface border border-apple-border-strong text-apple-text rounded-full text-[0.95rem] font-semibold hover:bg-apple-surface-hover transition-colors">
                {t('actions.email')}
              </a>
              <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="inline-flex w-full sm:w-auto items-center justify-center px-5 py-3 bg-apple-surface border border-apple-border-strong text-apple-text rounded-full text-[0.95rem] font-semibold hover:bg-apple-surface-hover transition-colors">
                {t('actions.instagram')}
              </a>
            </div>

            <p class="mt-6 text-[0.9rem] text-apple-muted font-medium leading-relaxed">
              {t('guidance.note')}
            </p>
          </article>

          <article class="rounded-3xl border border-apple-border bg-apple-surface overflow-hidden shadow-sm min-h-[360px]">
            <iframe
              src={mapEmbedSrc}
              class="w-full h-full min-h-[360px]"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={lang === 'en' ? 'Campus location on Google Maps' : lang === 'zh' ? '校园在 Google 地图上的位置' : 'Ubicación del campus en Google Maps'}
            ></iframe>
          </article>
        </div>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('routing.title')}</h2>
      <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[900px]">{t('routing.subtitle')}</p>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-5">
        <article class="rounded-2xl border border-apple-border bg-apple-surface-alt p-6">
          <h3 class="text-[1.08rem] font-bold">{t('routing.cards.admission.title')}</h3>
          <p class="mt-3 text-[0.94rem] text-apple-muted font-medium leading-relaxed">{t('routing.cards.admission.body')}</p>
          <a href={admissionUrl} class="mt-5 inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
            {t('routing.cards.admission.cta')} <span aria-hidden="true">&rarr;</span>
          </a>
        </article>

        <article class="rounded-2xl border border-apple-border bg-apple-surface-alt p-6">
          <h3 class="text-[1.08rem] font-bold">{t('routing.cards.career.title')}</h3>
          <p class="mt-3 text-[0.94rem] text-apple-muted font-medium leading-relaxed">{t('routing.cards.career.body')}</p>
          <a href={emailUrl} class="mt-5 inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
            {t('routing.cards.career.cta')} <span aria-hidden="true">&rarr;</span>
          </a>
        </article>

        <article class="rounded-2xl border border-apple-border bg-apple-surface-alt p-6">
          <h3 class="text-[1.08rem] font-bold">{t('routing.cards.projects.title')}</h3>
          <p class="mt-3 text-[0.94rem] text-apple-muted font-medium leading-relaxed">{t('routing.cards.projects.body')}</p>
          <a href={projectsUrl} class="mt-5 inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
            {t('routing.cards.projects.cta')} <span aria-hidden="true">&rarr;</span>
          </a>
        </article>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('social.title')}</h2>
      <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[920px]">{t('social.subtitle')}</p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-5 py-3 bg-apple-surface border border-apple-border-strong text-apple-text rounded-full text-[0.95rem] font-semibold hover:bg-apple-surface-hover transition-colors">
          {t('actions.instagram')}
        </a>
        <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-5 py-3 bg-apple-surface border border-apple-border-strong text-apple-text rounded-full text-[0.95rem] font-semibold hover:bg-apple-surface-hover transition-colors">
          {t('actions.facebook')}
        </a>
        <a href={tiktokUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-5 py-3 bg-apple-surface border border-apple-border-strong text-apple-text rounded-full text-[0.95rem] font-semibold hover:bg-apple-surface-hover transition-colors">
          {t('actions.tiktok')}
        </a>
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-5 py-3 bg-apple-surface border border-apple-border-strong text-apple-text rounded-full text-[0.95rem] font-semibold hover:bg-apple-surface-hover transition-colors">
          {t('actions.github')}
        </a>
      </div>
    </section>

    <section class="max-w-[840px] mx-auto px-5 sm:px-8 text-center border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-6">{t('cta.title')}</h2>
      <p class="text-[1.05rem] text-apple-muted font-medium leading-relaxed max-w-[760px] mx-auto mb-10">{t('cta.subtitle')}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={admissionUrl} class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-blue text-white text-[1rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]">
          {t('cta.primary')}
        </a>
        <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-surface border border-apple-border-strong text-apple-text text-[1rem] font-semibold rounded-full hover:bg-apple-surface-hover transition-colors">
          {t('cta.secondary')}
        </a>
      </div>
    </section>
  </main>
</Layout>
