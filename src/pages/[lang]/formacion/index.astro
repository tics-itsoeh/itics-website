---
/**
 * Página de Formación Académica (Retícula/Plan de Estudios).
 *
 * Arquitectura e Intención:
 * - Es la página más extensa en contenido institucional.
 * - Inyecta Schema.org de tipo `Course` para SEO, definiendo la carrera
 *   como un curso oficial provisto por el ITSOEH.
 * - Incluye un iframe embebido con el PDF oficial de la retícula. Dado que
 *   los iframes de PDFs fallan en iOS/móviles, se diseñó un fallback
 *   (`sm:hidden`) que muestra un botón de descarga directa en su lugar.
 * - TODO: Verificar si la retícula ITIC-2010-225 cambiará el próximo ciclo escolar.
 */
import Layout from '../../../layouts/Layout.astro';
import type { UiLanguage } from '../../../i18n/config';
import { languages } from '../../../i18n/config';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((language) => ({ params: { lang: language } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const t = useTranslations(lang, 'formation');
const tc = useTranslations(lang, 'common');

const overviewCards = ['objective', 'profile', 'curriculum', 'residency'] as const;
const identityCards = ['mission', 'vision', 'generalObjective'] as const;
const areaCards = ['software', 'networks', 'databases', 'math', 'iot', 'management'] as const;
const competencyCards = ['networks', 'software', 'databases', 'security', 'embedded', 'management'] as const;
const semesterCards = ['semester1', 'semester2', 'semester3', 'semester4', 'semester5', 'semester6', 'semester7', 'semester8', 'semester9'] as const;
const curriculumPdfPath = '/docs/tics.pdf';
import { siteUrl, institution } from '../../../data/siteConfig';

const labsContent = {
  es: {
    title: 'Laboratorios de Alto Rendimiento',
    subtitle: 'Espacios diseñados para llevar la teoría a la práctica. Contamos con equipamiento de nivel empresarial para que te prepares en entornos reales.',
    networking: { title: 'Laboratorio de Redes', desc: 'Aprende infraestructura, enrutamiento y telecomunicaciones con equipos físicos Cisco.' },
    mac: { title: 'Laboratorio de iMacs', desc: 'Desarrollo de Software, Interacción Humano-Computadora (IHC), Inteligencia Artificial, Estructura de Datos y Estadística.' },
    windows: { title: 'Laboratorio Multipropósito', desc: 'Programación, Sistemas Operativos (Linux Debian), Arquitectura de Computadoras y Servicios en la Nube sobre equipos Windows.' },
    stemTitle: 'Centro STEM Institucional',
    stemSubtitle: 'Además de nuestros laboratorios propios, hacemos uso extensivo de los laboratorios STEM de la universidad para competencias e innovación tecnológica.',
    stem_movil: { title: 'Robótica Móvil', desc: 'Equipos VEX V5 para diseño, construcción y competencias universitarias (VEXU).' },
    stem_educativa: { title: 'Robótica Educativa', desc: 'Desarrollo de lógica e ingeniería con equipos VEX IQ enfocados a competencias.' },
    stem_colaborativa: { title: 'Robótica Colaborativa', desc: 'Prácticas de automatización industrial con brazos robóticos Dobot.' },
    stem_vr: { title: 'Realidad Virtual', desc: 'Desarrollo de entornos inmersivos y simuladores con cascos Pico Neo 3 Pro.' },
    stem_iot: { title: 'Internet de las Cosas (IoT)', desc: 'Desarrollo de sistemas embebidos con maletines CrowPi y laptops Raspberry Pi.' }
  },
  en: {
    title: 'High-Performance Laboratories',
    subtitle: 'Spaces designed to put theory into practice. We have enterprise-level equipment so you can prepare in real environments.',
    networking: { title: 'Networking Laboratory', desc: 'Learn infrastructure, routing, and telecommunications with physical Cisco equipment.' },
    mac: { title: 'iMacs Laboratory', desc: 'Software Development, Human-Computer Interaction (HCI), Artificial Intelligence, Data Structures, and Statistics.' },
    windows: { title: 'Multipurpose Laboratory', desc: 'Programming, Operating Systems (Linux Debian), Computer Architecture, and Cloud Services on Windows PCs.' },
    stemTitle: 'Institutional STEM Center',
    stemSubtitle: 'In addition to our core labs, we make extensive use of the university\'s STEM laboratories for competitions and technological innovation.',
    stem_movil: { title: 'Mobile Robotics', desc: 'VEX V5 equipment for design, construction, and university competitions (VEXU).' },
    stem_educativa: { title: 'Educational Robotics', desc: 'Logic and engineering development with VEX IQ equipment focused on competitions.' },
    stem_colaborativa: { title: 'Collaborative Robotics', desc: 'Industrial automation practices with Dobot robotic arms.' },
    stem_vr: { title: 'Virtual Reality', desc: 'Development of immersive environments and simulators with Pico Neo 3 Pro headsets.' },
    stem_iot: { title: 'Internet of Things (IoT)', desc: 'Development of embedded systems with CrowPi kits and Raspberry Pi laptops.' }
  },
  zh: {
    title: '高性能实验室',
    subtitle: '旨在将理论付诸实践的空间。我们拥有企业级设备，让您在真实环境中做好准备。',
    networking: { title: '网络实验室', desc: '使用物理Cisco设备学习基础设施、路由和电信技术。' },
    mac: { title: 'iMac实验室', desc: '软件开发、人机交互 (HCI)、人工智能、数据结构和统计学。' },
    windows: { title: '多功能实验室', desc: '在Windows PC上进行编程、操作系统 (Linux Debian)、计算机体系结构和云服务。' },
    stemTitle: '机构 STEM 中心',
    stemSubtitle: '除了我们自己的实验室外，我们还广泛利用大学的 STEM 实验室进行竞赛和技术创新。',
    stem_movil: { title: '移动机器人', desc: '用于设计、制造和大学竞赛 (VEXU) 的 VEX V5 设备。' },
    stem_educativa: { title: '教育机器人', desc: '使用 VEX IQ 设备开发逻辑和工程能力，专注于竞赛。' },
    stem_colaborativa: { title: '协作机器人', desc: '使用 Dobot 机械臂进行工业自动化实践。' },
    stem_vr: { title: '虚拟现实', desc: '使用 Pico Neo 3 Pro 头显开发沉浸式环境和模拟器。' },
    stem_iot: { title: '物联网 (IoT)', desc: '使用 CrowPi 套件和 Raspberry Pi 笔记本电脑开发嵌入式系统。' }
  }
};
const lContent = labsContent[lang as keyof typeof labsContent] || labsContent.es;
const labsData = [
  { ...lContent.networking, img: '/images/labs/lab_networking_1777732012743.png' },
  { ...lContent.mac, img: '/images/labs/lab_software_mac_1777731999900.png' },
  { ...lContent.windows, img: '/images/labs/lab_windows_linux_1777732314372.png' }
];
const stemData = [
  { ...lContent.stem_movil, img: '/images/labs/lab_robotica_vex_1777732857633.png' },
  { ...lContent.stem_educativa, img: '/images/labs/lab_robotica_iq_1777732919858.png' },
  { ...lContent.stem_colaborativa, img: '/images/labs/lab_robotica_dobot_1777732877524.png' },
  { ...lContent.stem_vr, img: '/images/labs/lab_vr_1777732892063.png' },
  { ...lContent.stem_iot, img: '/images/labs/lab_iot_crowpi_1777732933904.png' }
];

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": institution.programName,
  "description": t('hero.subtitle'),
  "provider": {
    "@type": "EducationalOrganization",
    "name": institution.campusName,
    "sameAs": siteUrl
  }
};
---

<Layout lang={lang} title={tc('nav.formation')}>
  <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} slot="head" />

  <main class="bg-apple-surface min-h-screen pt-32 pb-24 text-apple-text overflow-x-hidden">
    <section class="max-w-[1024px] mx-auto px-5 sm:px-8 mb-20 text-center">
      <h1 class="text-[clamp(3rem,6vw,5rem)] font-black tracking-tight leading-[1] mb-6">{t('hero.title')}</h1>
      <p class="text-[1.2rem] md:text-[1.4rem] text-apple-muted font-medium leading-relaxed max-w-[820px] mx-auto">{t('hero.subtitle')}</p>
    </section>

    <section id="plan-estudios" class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {overviewCards.map((card) => (
          <article class="bg-apple-surface-alt rounded-2xl border border-apple-border p-6">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-apple-blue">{t(`overviewCards.${card}.label`)}</p>
            <h2 class="mt-3 text-xl font-bold">{t(`overviewCards.${card}.title`)}</h2>
            <p class="mt-3 text-sm leading-relaxed text-apple-muted">{t(`overviewCards.${card}.body`)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24">
      <div class="rounded-[2rem] border border-apple-border bg-gradient-to-b from-[#F5F8FF] to-[#F5F5F7] p-8 md:p-12">
        <h2 class="text-3xl font-bold tracking-tight">{t('identity.title')}</h2>
        <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
          {identityCards.map((card) => (
            <article class="rounded-2xl border border-apple-border bg-apple-surface p-6 md:p-7 shadow-[0_8px_20px_rgba(0,0,0,0.05)]">
              <h3 class="text-lg font-bold">{t(`identity.${card}.title`)}</h3>
              <p class="mt-3 text-sm text-apple-muted leading-relaxed">{t(`identity.${card}.body`)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24">
      <div class="rounded-[2rem] border border-apple-border bg-apple-surface-alt p-8 md:p-12">
        <h2 class="text-3xl font-bold tracking-tight">{t('areas.title')}</h2>
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          {areaCards.map((card) => (
            <article class="rounded-2xl border border-apple-border bg-apple-surface p-6">
              <h3 class="text-lg font-bold">{t(`areas.${card}.title`)}</h3>
              <p class="mt-2 text-sm text-apple-muted leading-relaxed">{t(`areas.${card}.body`)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24">
      <div class="rounded-[2rem] border border-apple-border bg-apple-surface-alt p-8 md:p-12">
        <h2 class="text-3xl font-bold tracking-tight">{t('competencies.title')}</h2>
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          {competencyCards.map((card) => (
            <article class="rounded-2xl border border-apple-border bg-apple-surface p-6">
              <h3 class="text-lg font-bold">{t(`competencies.${card}.title`)}</h3>
              <p class="mt-2 text-sm text-apple-muted leading-relaxed">{t(`competencies.${card}.body`)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24" id="reticula">
      <article class="rounded-[2rem] border border-apple-border bg-gradient-to-b from-[#F5F5F7] to-[#EEF5FF] p-8 md:p-12">
        <h2 class="text-[clamp(1.8rem,3vw,2.6rem)] font-bold tracking-tight">{t('curriculum.title')}</h2>
        <p class="mt-4 text-[1.05rem] leading-relaxed text-apple-muted max-w-[960px]">{t('curriculum.body')}</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href={curriculumPdfPath} target="_blank" rel="noopener noreferrer" class="inline-flex w-full sm:w-auto items-center justify-center px-6 sm:px-10 py-4 bg-apple-blue text-white text-[1.05rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]">
            {t('curriculum.button')}
          </a>
          <a href="#reticula-semestres" class="inline-flex w-full sm:w-auto items-center justify-center px-6 sm:px-10 py-4 rounded-full border border-apple-blue/30 text-apple-blue text-[1.02rem] font-semibold hover:bg-apple-surface/70 transition-all">
            {t('curriculum.summaryButton')}
          </a>
        </div>
      </article>

      <article class="mt-8 rounded-[2rem] border border-apple-border bg-apple-surface p-3 sm:p-4 md:p-5 shadow-sm">
        <div class="hidden sm:block overflow-hidden rounded-[1.25rem] border border-apple-border-strong bg-apple-surface-alt">
          <iframe
            src={`${curriculumPdfPath}#view=FitH`}
            title={t('iframeTitle')}
            loading="lazy"
            class="w-full h-[560px] sm:h-[680px] lg:h-[760px]"
          />
        </div>
        <div class="sm:hidden py-12 px-6 text-center border border-apple-border-strong rounded-[1.25rem] bg-apple-surface-alt">
          <svg class="w-12 h-12 mx-auto mb-4 text-apple-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <p class="text-apple-text font-medium mb-4">{t('iframeTitle')} no puede visualizarse en móviles.</p>
          <a href={curriculumPdfPath} target="_blank" rel="noopener noreferrer" class="inline-block w-full px-6 py-3 bg-apple-blue text-white font-semibold rounded-full shadow-sm hover:bg-apple-blue-hover transition-colors">
            {t('curriculum.button')}
          </a>
        </div>
      </article>

      <div id="reticula-semestres" class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {semesterCards.map((semester, index) => (
          <article class="rounded-2xl border border-apple-border bg-apple-surface p-6">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-apple-blue">{String(index + 1).padStart(2, '0')}</p>
            <p class="mt-3 text-sm leading-relaxed text-apple-muted">{t(`curriculum.${semester}`)}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- Laboratories -->
    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24" id="laboratorios">
      <div class="mb-14 text-center md:text-left">
        <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-4">{lContent.title}</h2>
        <p class="text-[1.15rem] text-apple-muted font-medium leading-relaxed max-w-[720px]">
          {lContent.subtitle}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
        {labsData.map((lab) => (
          <article class="bg-apple-surface-alt rounded-[2rem] border border-apple-border overflow-hidden group hover:shadow-[0_10px_30px_rgba(0,0,0,0.06)] transition-all duration-300 hover:-translate-y-1 flex flex-col">
            <div class="h-48 sm:h-56 overflow-hidden bg-apple-surface relative">
              <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors z-10"></div>
              <img src={lab.img} alt={lab.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            </div>
            <div class="p-6 md:p-8 flex-1 flex flex-col">
              <h3 class="text-[1.15rem] font-bold text-apple-text mb-3">{lab.title}</h3>
              <p class="text-[0.98rem] text-apple-muted font-medium leading-relaxed">{lab.desc}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="mb-14 pt-10 border-t border-apple-border text-center md:text-left">
        <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-4">{lContent.stemTitle}</h2>
        <p class="text-[1.15rem] text-apple-muted font-medium leading-relaxed max-w-[720px]">
          {lContent.stemSubtitle}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {stemData.map((lab) => (
          <article class="bg-apple-surface-alt rounded-[2rem] border border-apple-border overflow-hidden group hover:shadow-[0_10px_30px_rgba(0,0,0,0.06)] transition-all duration-300 hover:-translate-y-1 flex flex-col">
            <div class="h-48 sm:h-56 overflow-hidden bg-apple-surface relative">
              <div class="absolute inset-0 bg-black/5 group-hover:bg-transparent transition-colors z-10"></div>
              <img src={lab.img} alt={lab.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            </div>
            <div class="p-6 md:p-8 flex-1 flex flex-col">
              <h3 class="text-[1.15rem] font-bold text-apple-text mb-3">{lab.title}</h3>
              <p class="text-[0.98rem] text-apple-muted font-medium leading-relaxed">{lab.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-[1000px] mx-auto px-5 sm:px-8 mb-24">
      <article class="rounded-[2rem] border border-apple-border bg-apple-surface p-8 md:p-10 shadow-sm">
        <h2 class="text-3xl font-bold tracking-tight">{t('complementary.title')}</h2>
        <p class="mt-4 text-[1.05rem] leading-relaxed text-apple-muted mb-8">{t('complementary.body')}</p>
        <a href={`/${lang}/mentores#clubes`} class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
          Conocer los Clubes Estudiantiles <span aria-hidden="true">&rarr;</span>
        </a>
      </article>
    </section>

    <section class="max-w-[800px] mx-auto px-5 sm:px-8 text-center mb-20">
      <h2 class="text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight mb-8">{t('cta.title')}</h2>
      <a href={`/${lang}/proyectos`} class="inline-flex w-full sm:w-auto items-center justify-center px-6 sm:px-10 py-4 bg-apple-blue text-white text-[1.05rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]">
        {t('cta.button')}
      </a>
    </section>

    <section class="max-w-[800px] mx-auto px-5 sm:px-8 text-center border-t border-apple-border pt-14">
      <h2 class="text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight mb-6">{t('cta.admissionTitle')}</h2>
      <a href={`/${lang}/unirse`} class="inline-flex w-full sm:w-auto items-center justify-center px-6 sm:px-10 py-4 bg-apple-blue text-white text-[1.05rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]">
        {t('cta.admissionButton')}
      </a>
    </section>
  </main>
</Layout>
