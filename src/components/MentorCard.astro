---
export interface Props {
  name: string;
  role: string;
  tags: string[];
  githubHandle: string;
  githubUrl: string;
  image: string;
  profileUrl: string;
  profileLabel?: string;
}
const { name, role, tags, githubHandle, githubUrl, image, profileUrl, profileLabel = 'Ver perfil' } = Astro.props;
---
<div class="group flex flex-col h-full w-full max-w-[340px] mx-auto">
  <div class="aspect-[4/5] w-full overflow-hidden rounded-3xl bg-[#f5f5f7] mb-8 relative">
    <a href={profileUrl} class="block w-full h-full">
      <img src={image} alt={name} class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.03]" loading="lazy" decoding="async" />
    </a>
    <div class="absolute inset-0 ring-1 ring-inset ring-black/5 rounded-3xl pointer-events-none"></div>
  </div>
  <h3 class="text-[1.35rem] font-bold text-apple-text tracking-tight mb-1.5">{name}</h3>
  <p class="text-[0.95rem] font-medium text-apple-muted/80 mb-5">{role}</p>
  <div class="flex items-center gap-2 mb-6 flex-wrap">
    {tags.map(tag => (
      <span class="text-[0.75rem] font-semibold px-3.5 py-1.5 bg-[#f5f5f7] text-apple-text rounded-md tracking-wide">{tag}</span>
    ))}
  </div>
  <div class="flex items-center justify-between mt-auto pt-4 border-t border-black/5">
    <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[0.95rem] font-semibold text-apple-text hover:text-apple-blue transition-colors">
      <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
      </svg>
      {githubHandle}
    </a>
    <a href={profileUrl} class="text-[0.9rem] font-semibold text-apple-blue hover:text-apple-blue-hover transition-colors">
      {profileLabel} &rarr;
    </a>
  </div>
</div>
