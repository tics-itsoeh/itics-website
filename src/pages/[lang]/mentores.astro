---
/**
 * Página de Comunidad (Mentores, Egresados y Clubs).
 *
 * Arquitectura e Intención:
 * - Sirve como "prueba social". Demuestra que la carrera tiene una comunidad
 *   activa, tanto de egresados exitosos como de clubs estudiantiles.
 * - En lugar de usar CMS, extrae los perfiles de los archivos JSON de i18n
 *   (`mentors.json`). Esto mantiene el sitio estático, rápido y fácil de mantener.
 * - TODO: Reemplazar perfiles base por la plantilla oficial de docentes/mentores de este semestre.
 */
import Layout from '../../layouts/Layout.astro';
import Testimonials from '../../components/Testimonials.astro';
import type { UiLanguage } from '../../i18n/config';
import { languages } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const t = useTranslations(lang, 'mentors');
const tc = useTranslations(lang, 'common');

const facultyProfilesByLang = {
  es: [
    {
      slug: 'javier-cuadros',
      name: 'Dr. Francisco Javier Cuadros Romero',
      role: 'Profesor e investigador · IoT, IA y analítica de datos',
      photo: '/mentors/teachers/javiercuadros.webp',
      tags: ['IoT', 'Machine Learning', 'SQL'],
      credential: 'PhD',
      meta: 'Docencia e investigación ITICs',
    },
  ],
  en: [
    {
      slug: 'javier-cuadros',
      name: 'Dr. Francisco Javier Cuadros Romero',
      role: 'Professor and researcher · IoT, AI, and data analytics',
      photo: '/mentors/teachers/javiercuadros.webp',
      tags: ['IoT', 'Machine Learning', 'SQL'],
      credential: 'PhD',
      meta: 'ITICs Faculty and Research',
    },
  ],
  zh: [
    {
      slug: 'javier-cuadros',
      name: 'Dr. Francisco Javier Cuadros Romero',
      role: '教师与研究者 · IoT、AI 与数据分析',
      photo: '/mentors/teachers/javiercuadros.webp',
      tags: ['IoT', '机器学习', 'SQL'],
      credential: 'PhD',
      meta: 'ITICs 教学与研究',
    },
  ],
} as const;
const facultyProfiles = facultyProfilesByLang[lang] ?? facultyProfilesByLang.es;
const clubs = ['robotics', 'iot', 'developers', 'entrepreneurs'] as const;
const profileLinkLabelByLang = {
  es: 'Ver perfil',
  en: 'View profile',
  zh: '查看档案',
} as const;
const facultySliderPrevLabelByLang = {
  es: 'Ver docentes anteriores',
  en: 'View previous faculty',
  zh: '查看上一位教师',
} as const;
const facultySliderNextLabelByLang = {
  es: 'Ver siguientes docentes',
  en: 'View next faculty',
  zh: '查看下一位教师',
} as const;
const profileLinkLabel = profileLinkLabelByLang[lang] ?? profileLinkLabelByLang.es;
const facultySliderPrevLabel = facultySliderPrevLabelByLang[lang] ?? facultySliderPrevLabelByLang.es;
const facultySliderNextLabel = facultySliderNextLabelByLang[lang] ?? facultySliderNextLabelByLang.es;
---

<Layout lang={lang} title={tc('nav.mentors')}>
  <main class="bg-apple-surface min-h-screen pt-32 pb-24 text-apple-text overflow-x-hidden">
    <section class="max-w-[980px] mx-auto px-5 sm:px-8 mb-20 text-center">
      <h1 class="text-[clamp(3rem,6vw,5rem)] font-black tracking-tight leading-[1] mb-6">{t('community.hero.title')}</h1>
      <p class="text-[1.15rem] md:text-[1.35rem] text-apple-muted font-medium leading-relaxed max-w-[860px] mx-auto">
        {t('community.hero.subtitle')}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#clubes"
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-blue text-white text-[1rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]"
        >
          {t('community.hero.primary')}
        </a>
        <a
          href="#equipo"
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-surface border border-apple-border-strong text-apple-text text-[1rem] font-semibold rounded-full hover:bg-apple-surface-hover transition-colors"
        >
          {t('community.hero.secondary')}
        </a>
      </div>
    </section>

    <section id="equipo" class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('community.coordination.title')}</h2>
      <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[920px]">{t('community.coordination.subtitle')}</p>

      <article class="mt-8 rounded-[2rem] border border-apple-border bg-gradient-to-b from-[#F5F5F7] to-[#EEF5FF] p-7 md:p-10 shadow-sm">
        <div class="grid grid-cols-1 lg:grid-cols-[110px_1fr] gap-6 items-start">
          <div class="w-[88px] h-[88px] rounded-2xl bg-apple-surface border border-apple-border-strong inline-flex items-center justify-center text-[1.6rem] font-black tracking-tight text-apple-blue shadow-sm">
            JC
          </div>
          <div>
            <h3 class="text-[1.35rem] font-bold tracking-tight">{t('community.coordination.name')}</h3>
            <p class="mt-2 text-[1rem] text-apple-muted font-semibold leading-relaxed">{t('community.coordination.role')}</p>
            <p class="mt-4 text-[0.98rem] text-apple-muted font-medium leading-relaxed max-w-[860px]">{t('community.coordination.body')}</p>

            <div class="mt-6 flex flex-col sm:flex-row sm:flex-wrap gap-2.5 text-[0.93rem]">
              <a href="mailto:tics@itsoeh.edu.mx" class="inline-flex items-center px-4 py-2 rounded-full border border-apple-border-strong bg-apple-surface font-semibold text-apple-text hover:text-apple-blue transition-colors">
                {t('community.coordination.email')}
              </a>
              <a href="tel:+527387354000" class="inline-flex items-center px-4 py-2 rounded-full border border-apple-border-strong bg-apple-surface font-semibold text-apple-text hover:text-apple-blue transition-colors">
                {t('community.coordination.phone')}
              </a>
            </div>

            <div class="mt-6">
              <a href={`/${lang}/contacto`} class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
                {t('community.coordination.cta')} <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('community.faculty.title')}</h2>
      <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[930px]">{t('community.faculty.subtitle')}</p>

      <div data-faculty-slider class="mt-8" style="touch-action: pan-y;">
        <div class="mb-4 flex items-center justify-end gap-2">
          <button
            data-faculty-prev
            type="button"
            aria-label={facultySliderPrevLabel}
            class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-apple-border-strong bg-apple-surface text-apple-text hover:bg-apple-surface-hover transition-colors disabled:opacity-45 disabled:cursor-not-allowed"
          >
            <span aria-hidden="true">←</span>
          </button>
          <button
            data-faculty-next
            type="button"
            aria-label={facultySliderNextLabel}
            class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-apple-border-strong bg-apple-surface text-apple-text hover:bg-apple-surface-hover transition-colors disabled:opacity-45 disabled:cursor-not-allowed"
          >
            <span aria-hidden="true">→</span>
          </button>
        </div>

        <div data-faculty-viewport class="overflow-hidden">
          <div data-faculty-track class="flex flex-nowrap gap-6 transition-transform duration-500 ease-out">
            {facultyProfiles.map((teacher) => (
              <article class="group shrink-0 basis-[min(84vw,360px)] sm:basis-[320px] md:basis-[340px] rounded-[1.6rem] border border-apple-border/85 bg-apple-surface/70 p-4 sm:p-5 shadow-[0_10px_28px_rgba(15,23,42,0.04)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(15,23,42,0.08)]">
                <div class="aspect-[4/5] w-[91%] mx-auto overflow-hidden rounded-3xl bg-apple-surface shadow-sm">
                <img
                  src={teacher.photo}
                  alt={teacher.name}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                  decoding="async"
                />
              </div>

                <div class="mt-5">
                  <div class="mb-3 inline-flex items-center rounded-full border border-apple-border-strong bg-white/85 px-2.5 py-1 text-[0.7rem] font-bold uppercase tracking-[0.08em] text-apple-muted">
                    {teacher.credential}
                  </div>
                  <h3 class="text-[1.55rem] font-bold tracking-tight leading-tight">{teacher.name}</h3>
                  <p class="mt-2 text-[0.95rem] text-apple-muted font-medium leading-relaxed">{teacher.role}</p>

                  <div class="mt-4 flex flex-wrap gap-2">
                    {teacher.tags.map((tag) => (
                      <span class="px-3 py-1 bg-apple-surface text-[0.76rem] font-semibold rounded-lg text-apple-text">
                        {tag}
                      </span>
                    ))}
                  </div>

                  <div class="mt-6 border-t border-apple-border pt-5 flex items-center justify-between gap-3">
                    <p class="inline-flex items-center gap-2 text-[0.9rem] text-apple-text font-semibold">
                      <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                      </svg>
                      {teacher.meta}
                    </p>
                    <a href={`/${lang}/mentores/${teacher.slug}`} class="inline-flex items-center gap-2 text-[0.98rem] font-semibold text-apple-blue hover:underline hover:underline-offset-4">
                      {profileLinkLabel} <span aria-hidden="true">&rarr;</span>
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>

    </section>

    <section id="clubes" class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('community.clubs.title')}</h2>
      <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[930px]">{t('community.clubs.subtitle')}</p>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        {clubs.map((club) => {
          const link = t(`community.clubs.cards.${club}.url`);
          const hasExternalLink = /^https?:\/\//.test(link);

          return (
            <article class="rounded-2xl border border-apple-border bg-apple-surface-alt p-6 shadow-sm">
              <h3 class="text-[1.08rem] font-bold">{t(`community.clubs.cards.${club}.title`)}</h3>
              <p class="mt-3 text-[0.95rem] text-apple-muted font-medium leading-relaxed">{t(`community.clubs.cards.${club}.description`)}</p>

              {hasExternalLink && (
                <div class="mt-6">
                  <a
                    href={link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4"
                  >
                    {t(`community.clubs.cards.${club}.cta`)} <span aria-hidden="true">&rarr;</span>
                  </a>
                </div>
              )}
            </article>
          );
        })}
      </div>
    </section>

    <!-- Testimonials -->
    <Testimonials lang={lang} />

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-apple-border pt-14 md:pt-20">
      <article class="rounded-2xl border border-apple-border bg-apple-surface-alt p-7 md:p-8">
        <h2 class="text-[clamp(1.7rem,3vw,2.1rem)] font-bold tracking-tight">{t('community.credits.title')}</h2>
        <p class="mt-4 text-[1rem] text-apple-muted font-medium leading-relaxed max-w-[900px]">{t('community.credits.body')}</p>
        <div class="mt-6">
          <a href={`/${lang}/about`} class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
            {t('community.credits.aboutCta')} <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </article>
    </section>

    <section class="max-w-[840px] mx-auto px-5 sm:px-8 text-center border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-6">{t('community.cta.title')}</h2>
      <p class="text-[1.05rem] text-apple-muted font-medium leading-relaxed max-w-[760px] mx-auto mb-10">{t('community.cta.subtitle')}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`/${lang}/unirse`}
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-blue text-white text-[1rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]"
        >
          {t('community.cta.primary')}
        </a>
        <a
          href={`/${lang}/proyectos`}
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-surface border border-apple-border-strong text-apple-text text-[1rem] font-semibold rounded-full hover:bg-apple-surface-hover transition-colors"
        >
          {t('community.cta.secondary')}
        </a>
      </div>
    </section>
  </main>
</Layout>

<script>
  function initFacultySlider() {
    const sliders = Array.from(document.querySelectorAll('[data-faculty-slider]'));

    sliders.forEach((slider) => {
      if (!(slider instanceof HTMLElement)) return;
      if (slider.dataset.bound === '1') return;
      slider.dataset.bound = '1';

      const track = slider.querySelector('[data-faculty-track]');
      const previousButton = slider.querySelector('[data-faculty-prev]');
      const nextButton = slider.querySelector('[data-faculty-next]');

      if (!(track instanceof HTMLElement)) return;
      if (!(previousButton instanceof HTMLButtonElement)) return;
      if (!(nextButton instanceof HTMLButtonElement)) return;

      const cards = Array.from(track.children).filter((card) => card instanceof HTMLElement);
      if (cards.length === 0) return;

      let currentIndex = 0;
      let dragStartX = 0;
      let isDragging = false;

      const getStep = () => {
        const firstCard = cards[0];
        if (!(firstCard instanceof HTMLElement)) return 0;
        const styles = window.getComputedStyle(track);
        const gap = Number.parseFloat(styles.columnGap || styles.gap || '24');
        return firstCard.offsetWidth + (Number.isFinite(gap) ? gap : 24);
      };

      const updateSlider = () => {
        const maxIndex = Math.max(0, cards.length - 1);
        if (currentIndex > maxIndex) currentIndex = maxIndex;
        if (currentIndex < 0) currentIndex = 0;

        track.style.transform = `translateX(-${currentIndex * getStep()}px)`;
        previousButton.disabled = currentIndex === 0;
        nextButton.disabled = currentIndex === maxIndex;
      };

      const moveBy = (step: number) => {
        currentIndex += step;
        updateSlider();
      };

      const handleDragEnd = (endX: number) => {
        const delta = endX - dragStartX;
        if (Math.abs(delta) < 40) return;
        moveBy(delta < 0 ? 1 : -1);
      };

      previousButton.addEventListener('click', () => {
        moveBy(-1);
      });

      nextButton.addEventListener('click', () => {
        moveBy(1);
      });

      slider.addEventListener('touchstart', (event: TouchEvent) => {
        dragStartX = event.changedTouches[0]?.clientX ?? 0;
        isDragging = true;
      }, { passive: true });

      slider.addEventListener('touchend', (event: TouchEvent) => {
        if (!isDragging) return;
        isDragging = false;
        const endX = event.changedTouches[0]?.clientX ?? dragStartX;
        handleDragEnd(endX);
      }, { passive: true });

      slider.addEventListener('pointerdown', (event: PointerEvent) => {
        dragStartX = event.clientX;
        isDragging = true;
      });

      slider.addEventListener('pointerup', (event: PointerEvent) => {
        if (!isDragging) return;
        isDragging = false;
        handleDragEnd(event.clientX);
      });

      slider.addEventListener('pointercancel', () => {
        isDragging = false;
      });

      window.addEventListener('resize', updateSlider);
      updateSlider();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFacultySlider, { once: true });
  } else {
    initFacultySlider();
  }

  document.addEventListener('astro:page-load', initFacultySlider);
</script>
