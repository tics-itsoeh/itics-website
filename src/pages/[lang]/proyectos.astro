---
import Layout from '../../layouts/Layout.astro';
import type { UiLanguage } from '../../i18n/config';
import { languages } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const t = useTranslations(lang, 'projects');
const tc = useTranslations(lang, 'common');

const categories = ['ia', 'software', 'iot', 'networks', 'data', 'robotics', 'web', 'embedded'] as const;
const featuredTags = ['projects', 'github', 'contests', 'community', 'portfolio'] as const;
const evidenceCards = ['virtualMuseum', 'dynamicMuseum', 'esp32', 'vex', 'github'] as const;
const lineCards = ['software', 'iot', 'networks', 'data', 'robotics', 'hci'] as const;

const githubUrl = t('v2.links.githubUrl');
const communityUrl = `/${lang}/mentores`;
---

<Layout lang={lang} title={tc('nav.projects')}>
  <main class="bg-white min-h-screen pt-32 pb-24 text-apple-text overflow-x-hidden">

    <section class="max-w-[1024px] mx-auto px-5 sm:px-8 mb-20 text-center">
      <h1 class="text-[clamp(3rem,6vw,5.2rem)] font-black tracking-tight leading-[1] mb-6">{t('v2.hero.title')}</h1>
      <p class="text-[1.15rem] md:text-[1.38rem] text-apple-muted font-medium leading-relaxed max-w-[900px] mx-auto mb-10">
        {t('v2.hero.subtitle')}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#evidencias"
          class="inline-flex w-full sm:w-auto items-center justify-center px-6 sm:px-9 py-4 bg-apple-blue text-white text-[1rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]"
        >
          {t('v2.hero.primary')}
        </a>
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full sm:w-auto items-center justify-center px-6 sm:px-9 py-4 bg-white border border-black/10 text-apple-text text-[1rem] font-semibold rounded-full hover:bg-black/[0.03] transition-colors"
        >
          {t('v2.hero.secondary')}
        </a>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24">
      <p class="text-[0.78rem] uppercase tracking-[0.2em] font-semibold text-apple-muted text-center mb-5">{t('v2.categories.title')}</p>
      <div class="flex flex-wrap items-center justify-center gap-2.5">
        {categories.map((category) => (
          <span class="inline-flex items-center px-4 py-2 rounded-full border border-black/10 bg-[#F5F5F7] text-[0.85rem] font-semibold text-apple-text">
            {t(`v2.categories.${category}`)}
          </span>
        ))}
      </div>
    </section>

    <section id="destacado" class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24">
      <article class="rounded-[2.2rem] border border-black/5 bg-gradient-to-b from-[#F5F5F7] to-[#EEF5FF] p-8 md:p-12 lg:p-14 relative overflow-hidden">
        <div class="absolute -top-24 -right-24 w-80 h-80 bg-apple-blue/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-cyan-400/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-8 items-center">
          <div>
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-apple-blue/10 text-apple-blue text-[0.72rem] font-bold uppercase tracking-[0.12em] border border-apple-blue/20">{t('v2.featured.label')}</span>
            <h2 class="mt-5 text-[clamp(1.9rem,3.2vw,2.8rem)] font-bold tracking-tight">{t('v2.featured.title')}</h2>
            <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[860px]">{t('v2.featured.description')}</p>

            <div class="mt-7 flex flex-wrap gap-2">
              {featuredTags.map((tag) => (
                <span class="px-3 py-1 bg-white text-[0.8rem] font-semibold rounded-full border border-black/10 text-apple-text shadow-sm">
                  {t(`v2.featured.tags.${tag}`)}
                </span>
              ))}
            </div>

            <div class="mt-8 flex flex-col sm:flex-row gap-3">
              <a href="#evidencias" class="inline-flex w-full sm:w-auto items-center justify-center px-6 py-3 bg-apple-blue text-white rounded-full text-[0.95rem] font-semibold hover:bg-apple-blue-hover transition-colors">
                {t('v2.featured.primary')}
              </a>
              <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex w-full sm:w-auto items-center justify-center px-6 py-3 bg-white border border-black/10 text-apple-text rounded-full text-[0.95rem] font-semibold hover:bg-black/[0.03] transition-colors">
                {t('v2.featured.secondary')}
              </a>
            </div>
          </div>

          <div class="rounded-2xl border border-black/10 bg-white p-6 md:p-8 shadow-sm">
            <p class="text-[0.78rem] uppercase tracking-[0.16em] font-semibold text-apple-muted">ITICs</p>
            <h3 class="mt-3 text-[1.25rem] font-bold tracking-tight">{t('v2.featured.cardTitle')}</h3>
            <p class="mt-3 text-[0.95rem] text-apple-muted font-medium leading-relaxed">
              {t('v2.featured.cardBody')}
            </p>
            <div class="mt-6 h-px bg-black/10"></div>
            <div class="mt-6 grid grid-cols-2 gap-3">
              <div class="rounded-xl bg-[#F5F5F7] border border-black/5 p-3">
                <p class="text-[0.72rem] uppercase tracking-[0.14em] font-semibold text-apple-muted">{t('v2.featured.repoLabel')}</p>
                <p class="mt-1 text-[0.9rem] font-bold">{t('v2.featured.repoValue')}</p>
              </div>
              <div class="rounded-xl bg-[#F5F5F7] border border-black/5 p-3">
                <p class="text-[0.72rem] uppercase tracking-[0.14em] font-semibold text-apple-muted">{t('v2.featured.areaLabel')}</p>
                <p class="mt-1 text-[0.9rem] font-bold">{t('v2.featured.areaValue')}</p>
              </div>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section id="evidencias" class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-black/5 pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.8rem)] font-bold tracking-tight">{t('v2.evidence.title')}</h2>
      <p class="mt-4 text-[1.05rem] text-apple-muted font-medium leading-relaxed max-w-[920px]">{t('v2.evidence.subtitle')}</p>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {evidenceCards.map((card) => {
          const primaryUrl = t(`v2.evidence.cards.${card}.primaryUrl`);
          const secondaryUrl = card === 'github' ? `/${lang}/mentores` : t(`v2.evidence.cards.${card}.secondaryUrl`);
          const isPrimaryExternal = /^https?:\/\//.test(primaryUrl);
          const isSecondaryExternal = /^https?:\/\//.test(secondaryUrl);

          return (
            <article class="rounded-2xl border border-black/5 bg-[#F5F5F7] p-6 shadow-sm">
              <h3 class="text-[1.12rem] font-bold leading-tight">{t(`v2.evidence.cards.${card}.title`)}</h3>
              <p class="mt-3 text-[0.95rem] text-apple-muted font-medium leading-relaxed">{t(`v2.evidence.cards.${card}.description`)}</p>

              <div class="mt-5 flex flex-wrap gap-2">
                {['tag1', 'tag2', 'tag3', 'tag4'].map((tagKey) => (
                  <span class="px-2.5 py-1 bg-white text-[0.75rem] font-semibold rounded-md border border-black/8 text-apple-text">
                    {t(`v2.evidence.cards.${card}.${tagKey}`)}
                  </span>
                ))}
              </div>

              <div class="mt-6 flex flex-col sm:flex-row gap-2.5">
                <a
                  href={primaryUrl}
                  target={isPrimaryExternal ? '_blank' : undefined}
                  rel={isPrimaryExternal ? 'noopener noreferrer' : undefined}
                  class="inline-flex w-full sm:w-auto items-center justify-center px-4 py-2.5 bg-apple-blue text-white rounded-full text-[0.88rem] font-semibold hover:bg-apple-blue-hover transition-colors"
                >
                  {t(`v2.evidence.cards.${card}.primaryLabel`)}
                </a>
                <a
                  href={secondaryUrl}
                  target={isSecondaryExternal ? '_blank' : undefined}
                  rel={isSecondaryExternal ? 'noopener noreferrer' : undefined}
                  class="inline-flex w-full sm:w-auto items-center justify-center px-4 py-2.5 bg-white border border-black/10 text-apple-text rounded-full text-[0.88rem] font-semibold hover:bg-black/[0.03] transition-colors"
                >
                  {t(`v2.evidence.cards.${card}.secondaryLabel`)}
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-black/5 pt-14 md:pt-20">
      <div class="rounded-[2rem] border border-black/5 bg-[#F5F5F7] p-8 md:p-12">
        <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('v2.lines.title')}</h2>
        <p class="mt-4 text-[1.04rem] text-apple-muted font-medium leading-relaxed max-w-[930px]">{t('v2.lines.subtitle')}</p>

        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
          {lineCards.map((card) => (
            <article class="rounded-2xl border border-black/5 bg-white p-6">
              <h3 class="text-[1.06rem] font-bold">{t(`v2.lines.cards.${card}.title`)}</h3>
              <p class="mt-3 text-[0.94rem] text-apple-muted font-medium leading-relaxed">{t(`v2.lines.cards.${card}.description`)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-[850px] mx-auto px-5 sm:px-8 text-center border-t border-black/5 pt-14 md:pt-20">
      <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-6">{t('v2.cta.title')}</h2>
      <p class="text-[1.05rem] text-apple-muted font-medium leading-relaxed max-w-[760px] mx-auto mb-10">{t('v2.cta.body')}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-blue text-white text-[1rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]"
        >
          {t('v2.cta.primary')}
        </a>
        <a
          href={communityUrl}
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-white border border-black/10 text-apple-text text-[1rem] font-semibold rounded-full hover:bg-black/[0.03] transition-colors"
        >
          {t('v2.cta.secondary')}
        </a>
      </div>
    </section>

  </main>
</Layout>
