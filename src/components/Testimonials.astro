const content = translations[lang] || translations['es'];
---

<section class="max-w-[1200px] mx-auto px-5 sm:px-8 pb-20 md:pb-32 border-t border-apple-border pt-14 md:pt-20">
  <div class="mb-14 text-center md:text-left">
    <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-4">{content.title}</h2>
    <p class="text-[1.15rem] text-apple-muted font-medium leading-relaxed max-w-[720px]">
      {content.subtitle}
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <article class="bg-apple-surface rounded-[2rem] p-7 sm:p-8 border border-apple-border">
      <h3 class="text-[1.1rem] font-bold text-apple-text mb-5">{content.communityTitle}</h3>
      <div class="space-y-4">
        {content.communityQuotes.map((quote) => (
          <p class="rounded-xl border border-apple-border bg-apple-surface-alt px-4 py-3 text-[0.95rem] text-apple-text font-medium leading-relaxed">
            "{quote}"
          </p>
        ))}
      </div>
    </article>

    <article class="bg-apple-surface rounded-[2rem] p-7 sm:p-8 border border-apple-border">
      <h3 class="text-[1.1rem] font-bold text-apple-text mb-5">{content.alumniTitle}</h3>
      <div data-alumni-slider class="relative" tabindex="0" style="touch-action: pan-y;">
        <div class="overflow-hidden rounded-2xl border border-apple-border bg-apple-surface-alt">
          <div data-slider-track class="flex transition-transform duration-500 ease-out">
            {content.alumniSlides.map((slide) => (
              <article class="w-full shrink-0 p-5 sm:p-6">
                <div class="relative overflow-hidden rounded-2xl border border-apple-border bg-apple-surface h-[240px] sm:h-[280px] mb-5">
                  <img
                    src={slide.photo}
                    alt={slide.photoAlt}
                    loading="lazy"
                    class="w-full h-full object-cover"
                  />
                  <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/65 to-transparent px-4 py-4">
                    <p class="text-white text-[1rem] font-semibold leading-tight">{slide.name}</p>
                    <p class="text-white/85 text-[0.8rem] font-medium mt-1">{slide.role}</p>
                  </div>
                </div>
                <p class="text-[0.98rem] text-apple-text font-medium leading-relaxed">
                  "{slide.quote}"
                </p>
              </article>
            ))}
          </div>
        </div>

        <div class="mt-5 flex items-center justify-between gap-4">
          <button
            data-slider-prev
            type="button"
            aria-label={content.sliderPrev}
            class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-apple-border-strong bg-apple-surface text-apple-text hover:bg-apple-surface-hover transition-colors"
          >
            <span aria-hidden="true">←</span>
          </button>

          <div class="flex items-center gap-2">
            {content.alumniSlides.map((_, index) => (
              <button
                type="button"
                data-slider-dot
                data-index={index}
                class="w-2.5 h-2.5 rounded-full bg-apple-border-strong transition-all"
                aria-label={`Slide ${index + 1}`}
              ></button>
            ))}
          </div>

          <button
            data-slider-next
            type="button"
            aria-label={content.sliderNext}
            class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-apple-border-strong bg-apple-surface text-apple-text hover:bg-apple-surface-hover transition-colors"
          >
            <span aria-hidden="true">→</span>
          </button>
        </div>
      </div>
    </article>
  </div>
</section>

<script>
  function initTestimonialsSlider() {
    const sliders = Array.from(document.querySelectorAll('[data-alumni-slider]'));

    sliders.forEach((slider) => {
      if (!(slider instanceof HTMLElement)) return;
      if (slider.dataset.bound === '1') return;
      slider.dataset.bound = '1';

      const track = slider.querySelector('[data-slider-track]');
      const previousButton = slider.querySelector('[data-slider-prev]');
      const nextButton = slider.querySelector('[data-slider-next]');
      const dots = Array.from(slider.querySelectorAll('[data-slider-dot]'));

      if (!(track instanceof HTMLElement) || dots.length === 0) return;

      const slidesCount = dots.length;
      let currentIndex = 0;
      let dragStartX = 0;
      let isDragging = false;

      const updateSlider = () => {
        track.style.transform = `translateX(-${currentIndex * 100}%)`;
        dots.forEach((dot, index) => {
          const active = index === currentIndex;
          dot.classList.toggle('bg-apple-blue', active);
          dot.classList.toggle('scale-110', active);
          dot.classList.toggle('bg-apple-border-strong', !active);
          dot.setAttribute('aria-current', active ? 'true' : 'false');
        });
      };

      const goTo = (index: number) => {
        currentIndex = (index + slidesCount) % slidesCount;
        updateSlider();
      };

      const handleDragEnd = (endX: number) => {
        const delta = endX - dragStartX;
        if (Math.abs(delta) < 40) return;
        goTo(currentIndex + (delta < 0 ? 1 : -1));
      };

      previousButton?.addEventListener('click', () => goTo(currentIndex - 1));
      nextButton?.addEventListener('click', () => goTo(currentIndex + 1));

      dots.forEach((dot) => {
        if (!(dot instanceof HTMLButtonElement)) return;
        dot.addEventListener('click', () => {
          const target = Number(dot.dataset.index || '0');
          goTo(target);
        });
      });

      slider.addEventListener('keydown', (event: KeyboardEvent) => {
        if (event.key === 'ArrowLeft') goTo(currentIndex - 1);
        if (event.key === 'ArrowRight') goTo(currentIndex + 1);
      });

      slider.addEventListener('touchstart', (event: TouchEvent) => {
        dragStartX = event.changedTouches[0]?.clientX ?? 0;
        isDragging = true;
      }, { passive: true });

      slider.addEventListener('touchend', (event: TouchEvent) => {
        if (!isDragging) return;
        isDragging = false;
        const endX = event.changedTouches[0]?.clientX ?? dragStartX;
        handleDragEnd(endX);
      }, { passive: true });

      slider.addEventListener('pointerdown', (event: PointerEvent) => {
        dragStartX = event.clientX;
        isDragging = true;
      });

      slider.addEventListener('pointerup', (event: PointerEvent) => {
        if (!isDragging) return;
        isDragging = false;
        handleDragEnd(event.clientX);
      });

      slider.addEventListener('pointercancel', () => {
        isDragging = false;
      });

      updateSlider();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTestimonialsSlider, { once: true });
  } else {
    initTestimonialsSlider();
  }

  document.addEventListener('astro:page-load', initTestimonialsSlider);
</script>
