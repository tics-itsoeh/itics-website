---
import Layout from '../../../layouts/Layout.astro';
import type { UiLanguage } from '../../../i18n/config';
import { languages } from '../../../i18n/config';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((language) => ({ params: { lang: language } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const t = useTranslations(lang, 'formation');
const tc = useTranslations(lang, 'common');

const steps = ['step1', 'step2', 'step3', 'step4'] as const;
const features = ['repos', 'challenges', 'codeReviews', 'systems'] as const;
---

<Layout lang={lang} title={tc('nav.formation')}>
  <main class="bg-white min-h-screen pt-32 pb-24 text-apple-text overflow-x-hidden">
    <section class="max-w-[1000px] mx-auto px-8 mb-20 text-center">
      <h1 class="text-[clamp(3rem,6vw,5rem)] font-black tracking-tight leading-[1] mb-6">{t('hero.title')}</h1>
      <p class="text-[1.2rem] md:text-[1.4rem] text-apple-muted font-medium leading-relaxed max-w-[820px] mx-auto">{t('hero.subtitle')}</p>
    </section>

    <section class="max-w-[1200px] mx-auto px-8 mb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {steps.map((step) => (
          <article class="bg-[#F5F5F7] rounded-2xl border border-black/5 p-6">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-apple-blue">{t(`howItWorks.${step}.label`)}</p>
            <h2 class="mt-3 text-xl font-bold">{t(`howItWorks.${step}.title`)}</h2>
            <p class="mt-3 text-sm leading-relaxed text-apple-muted">{t(`howItWorks.${step}.body`)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-8 mb-24">
      <div class="rounded-[2rem] border border-black/5 bg-[#F5F5F7] p-8 md:p-12">
        <h2 class="text-3xl font-bold tracking-tight">{t('features.title')}</h2>
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
          {features.map((feature) => (
            <article class="rounded-2xl border border-black/5 bg-white p-6">
              <h3 class="text-lg font-bold">{t(`features.${feature}.title`)}</h3>
              <p class="mt-2 text-sm text-apple-muted leading-relaxed">{t(`features.${feature}.body`)}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="max-w-[1000px] mx-auto px-8 mb-24">
      <article class="rounded-[2rem] border border-black/5 bg-white p-8 md:p-10 shadow-sm">
        <h2 class="text-3xl font-bold tracking-tight">{t('collaboration.title')}</h2>
        <p class="mt-4 text-[1.05rem] leading-relaxed text-apple-muted">{t('collaboration.body')}</p>
      </article>
    </section>

    <section class="max-w-[800px] mx-auto px-8 text-center">
      <h2 class="text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight mb-8">{t('cta.title')}</h2>
      <a href={`/${lang}/proyectos`} class="inline-flex items-center justify-center px-10 py-4 bg-apple-blue text-white text-[1.05rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]">
        {tc('cta.exploreProjects')}
      </a>
    </section>
  </main>
</Layout>
