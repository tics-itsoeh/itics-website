---
/**
 * Layout principal del sitio ITICs ITSOEH.
 *
 * Arquitectura (App Shell):
 * Este componente envuelve todas las páginas del sitio. 
 * Responsabilidades exclusivas:
 * 1. Inyectar SEO dinámico (OG tags, Twitter Cards, canonical URL).
 * 2. Cargar el Schema.org (EducationalOrganization) para rich snippets de Google.
 * 3. Montar el SiteLoader, Navbar y Footer alrededor del slot principal.
 * 4. Controlar dependencias globales (Lenis para smooth scroll, CSS base).
 *
 * @prop title — Título de la página (se concatena con "Ing. TICs - ")
 * @prop description — Meta description para SEO
 * @prop lang — Idioma de la página (default: detectado de URL)
 * @prop hideJoinCta — Oculta el CTA de admisión en nav (ej. en la propia página de unirse)
 */
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { UiLanguage } from '../i18n/config';
import { languages } from '../i18n/config';
import { siteUrl, institution } from '../data/siteConfig';
import SiteLoader from '../components/layout/SiteLoader.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: UiLanguage;
  hideJoinCta?: boolean;
}

const lang: UiLanguage = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tc = useTranslations(lang, 'common');

const {
  title = tc('nav.home'),
  description = tc('footer.tagline'),
  hideJoinCta = false,
} = Astro.props;
const pageTitle = String(title).trim() || tc('nav.home');
const fullTitle = `${institution.shortName} - ${pageTitle}`;

const currentPath = Astro.url.pathname;

// Alternate lang hrefs — SEO hreflang
const alternateLinks = Object.keys(languages).map(code => ({
  code,
  path: currentPath.replace(`/${lang}`, `/${code}`),
}));
const defaultPath = `/es${currentPath.replace(`/${lang}`, '')}`;

// Canonical URL
const canonicalUrl = `${siteUrl}${currentPath}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/icon.png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/icon-180.webp" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Hreflang alternates */}
    {alternateLinks.map(({ code, path }) => (
      <link rel="alternate" hreflang={code} href={`${siteUrl}${path}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${defaultPath}`} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={institution.programName} />
    <meta property="og:locale" content={lang === 'es' ? 'es_MX' : lang === 'zh' ? 'zh_CN' : 'en_US'} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    {/* Schema.org — EducationalOrganization */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": institution.programName,
      "alternateName": ["ITICs", institution.shortName],
      "url": siteUrl,
      "parentOrganization": {
        "@type": "CollegeOrUniversity",
        "name": institution.campusName,
        "alternateName": institution.campusShort,
        "parentOrganization": {
          "@type": "Organization",
          "name": institution.system,
          "alternateName": institution.systemShort,
        },
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+52-772-139-7096",
        "email": "tics@itsoeh.edu.mx",
        "contactType": "admissions",
      },
      "sameAs": [
        "https://www.instagram.com/itics.itsoeh",
        "https://www.facebook.com/ITIC.ITSOEHmx",
        "https://www.tiktok.com/@ing.tics",
        "https://github.com/tics-itsoeh",
      ],
    })} />

    {/* Fonts — preconnect + Inter */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <SiteLoader />
    <Navbar lang={lang} currentPath={currentPath} hideJoinCta={hideJoinCta} />
    <div id="page-scroll-content">
      <slot />
      <Footer lang={lang} />
    </div>
    <script>
      const loaderSeenKey = 'itics-loader-seen';
      let lenis: { raf: (time: number) => void; destroy: () => void } | null = null;
      let lenisRafId: number | null = null;

      function destroySmoothScroll() {
        if (lenisRafId !== null) {
          window.cancelAnimationFrame(lenisRafId);
          lenisRafId = null;
        }
        if (lenis) {
          lenis.destroy();
          lenis = null;
        }
      }

      async function setupSmoothScroll() {
        if (lenis) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        try {
          const { default: Lenis } = await import('lenis');
          const scrollContent = document.getElementById('page-scroll-content') as HTMLElement | null;
          lenis = new Lenis({
            wrapper: window,
            content: scrollContent ?? document.documentElement,
            duration: 1.1,
            smoothWheel: true,
            wheelMultiplier: 0.9,
            touchMultiplier: 1.05,
            easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            anchors: true,
          });

          const raf = (time: number) => {
            if (!lenis) return;
            lenis.raf(time);
            lenisRafId = window.requestAnimationFrame(raf);
          };

          lenisRafId = window.requestAnimationFrame(raf);
        } catch (error) {
          destroySmoothScroll();
          console.warn('Smooth scroll initialization failed, using native scroll.', error);
        }
      }

      // Loader helpers
      function showSiteLoader() {
        const loader = document.getElementById('site-loader');
        if (!loader) return;
        loader.classList.remove('site-loader--hidden');
        document.body.classList.add('is-loading');
      }

      function hideSiteLoader() {
        const loader = document.getElementById('site-loader');
        if (!loader) return;
        loader.classList.add('site-loader--hidden');
        document.body.classList.remove('is-loading');
      }

      function hasSeenLoader() {
        try {
          return window.sessionStorage.getItem(loaderSeenKey) === '1';
        } catch {
          return false;
        }
      }

      function markLoaderSeen() {
        try {
          window.sessionStorage.setItem(loaderSeenKey, '1');
        } catch {
          // Ignore storage access errors and continue gracefully.
        }
      }

      // Nav pill animation
      function setupNav() {
        const container = document.getElementById('nav-container');
        const pill = document.getElementById('nav-pill');
        const links = document.querySelectorAll('.nav-link');

        if (!container || !pill || links.length === 0) return;

        let activeLink = document.querySelector('.active-nav-item') as HTMLElement;

        function movePill(el: HTMLElement) {
          if (!pill) return;
          pill.style.opacity = '1';
          pill.style.width = `${el.offsetWidth}px`;
          pill.style.transform = `translateX(${el.offsetLeft}px)`;
        }

        if (activeLink) movePill(activeLink);

        links.forEach(link => {
          link.addEventListener('mouseenter', (e) => movePill(e.target as HTMLElement));
        });

        container.addEventListener('mouseleave', () => {
          if (activeLink) movePill(activeLink);
          else pill.style.opacity = '0';
        });
      }

      // Mobile menu
      function setupMobileMenu() {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        if (!toggle || !menu) return;
        if (toggle.getAttribute('data-menu-bound') === 'true') return;

        const closeMenu = () => {
          menu.classList.add('hidden');
          toggle.setAttribute('aria-expanded', 'false');
        };

        const toggleMenu = () => {
          const isOpen = !menu.classList.contains('hidden');
          if (isOpen) closeMenu();
          else {
            menu.classList.remove('hidden');
            toggle.setAttribute('aria-expanded', 'true');
          }
        };

        toggle.addEventListener('click', (event) => {
          event.stopPropagation();
          toggleMenu();
        });

        menu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeMenu);
        });

        toggle.setAttribute('data-menu-bound', 'true');
      }

      // Language switcher — keyboard accessible toggle
      function setupLangSwitcher() {
        const btn = document.getElementById('lang-switcher-btn');
        const menu = document.getElementById('lang-switcher-menu');
        if (!btn || !menu) return;
        if (btn.getAttribute('data-lang-bound') === 'true') return;

        const show = () => {
          menu.classList.remove('opacity-0', 'invisible', 'translate-y-1');
          menu.classList.add('opacity-100', 'visible', 'translate-y-0');
          btn.setAttribute('aria-expanded', 'true');
        };

        const hide = () => {
          menu.classList.add('opacity-0', 'invisible', 'translate-y-1');
          menu.classList.remove('opacity-100', 'visible', 'translate-y-0');
          btn.setAttribute('aria-expanded', 'false');
        };

        btn.addEventListener('click', () => {
          const isOpen = btn.getAttribute('aria-expanded') === 'true';
          if (isOpen) hide(); else show();
        });

        // Also support hover for mouse users
        const wrapper = document.getElementById('lang-switcher');
        if (wrapper) {
          wrapper.addEventListener('mouseenter', show);
          wrapper.addEventListener('mouseleave', hide);
        }

        // Close on Escape
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
            hide();
            btn.focus();
          }
        });

        // Close on outside click
        document.addEventListener('click', (e) => {
          if (wrapper && !wrapper.contains(e.target as Node)) {
            hide();
          }
        });

        btn.setAttribute('data-lang-bound', 'true');
      }

      // Initialize
      setupNav();
      setupMobileMenu();
      setupLangSwitcher();
      setupSmoothScroll();
      document.addEventListener('astro:page-load', setupNav);
      document.addEventListener('astro:page-load', setupMobileMenu);
      document.addEventListener('astro:page-load', setupLangSwitcher);
      document.addEventListener('astro:page-load', setupSmoothScroll);
      document.addEventListener('astro:before-preparation', destroySmoothScroll);

      // First-visit loader
      if (!hasSeenLoader()) {
        markLoaderSeen();
        showSiteLoader();
        const finishFirstLoadAnimation = () => hideSiteLoader();
        document.addEventListener('astro:page-load', finishFirstLoadAnimation, { once: true });
        window.addEventListener('load', finishFirstLoadAnimation, { once: true });
        window.setTimeout(finishFirstLoadAnimation, 2600);
      } else {
        hideSiteLoader();
      }

      // Service Worker registration
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch((err) => {
            console.warn('Service worker registration failed:', err);
          });
        });
      }
    </script>
  </body>
</html>
