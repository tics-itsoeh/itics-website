---
import '../styles/global.css';
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { UiLanguage } from '../i18n/config';
import { languages } from '../i18n/config';

interface Props {
  title?: string;
  description?: string;
  lang?: UiLanguage;
  hideJoinCta?: boolean;
}

const lang: UiLanguage = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tc = useTranslations(lang, 'common');

const {
  title = tc('nav.home'),
  description = tc('footer.tagline'),
  hideJoinCta = false,
} = Astro.props;
const pageTitle = String(title).trim() || tc('nav.home');
const fullTitle = `Ing. TICs - ${pageTitle}`;

const currentPath = Astro.url.pathname;

const navItems = [
  { path: `/${lang}`,           label: tc('nav.home')     },
  { path: `/${lang}/formacion`, label: tc('nav.formation') },
  { path: `/${lang}/proyectos`,  label: tc('nav.projects') },
  { path: `/${lang}/mentores`,   label: tc('nav.mentors')  },
  { path: `/${lang}/contacto`,   label: tc('nav.contact')  },
];

// Alternate lang hrefs for <link rel="alternate"> — good for SEO
const alternateLinks = Object.keys(languages).map(code => ({
  code,
  path: currentPath.replace(`/${lang}`, `/${code}`)
}));
const defaultPath = `/es${currentPath.replace(`/${lang}`, '')}`;
const currentYear = new Date().getFullYear();

const footerCopy: Record<UiLanguage, {
  siteLabel: string;
  navigationLabel: string;
  quickLinksLabel: string;
  contactLabel: string;
  addressLabel: string;
  phoneLabel: string;
  emailLabel: string;
  address: string;
  phone: string;
  email: string;
  footnote: string;
  institution: string;
  rights: string;
}> = {
  es: {
    siteLabel: 'Sitio oficial',
    navigationLabel: 'Navegación',
    quickLinksLabel: 'Enlaces rápidos',
    contactLabel: 'Contacto',
    addressLabel: 'Dirección',
    phoneLabel: 'Teléfono',
    emailLabel: 'Correo',
    address: 'Carretera México - Pachuca Km. 87.5',
    phone: '773-109-9748',
    email: 'itics@itsoeh.edu.mx',
    footnote: 'Espacio académico enfocado en ingeniería aplicada, problemas reales y colaboración técnica.',
    institution: 'Instituto Tecnológico Superior de Occidente del Estado de Hidalgo',
    rights: 'Todos los derechos reservados.',
  },
  en: {
    siteLabel: 'Official site',
    navigationLabel: 'Navigation',
    quickLinksLabel: 'Quick links',
    contactLabel: 'Contact',
    addressLabel: 'Address',
    phoneLabel: 'Phone',
    emailLabel: 'Email',
    address: 'Mexico - Pachuca Highway Km. 87.5',
    phone: '773-109-9748',
    email: 'itics@itsoeh.edu.mx',
    footnote: 'Academic space focused on applied engineering, real problems, and technical collaboration.',
    institution: 'Technological Institute of Western Hidalgo State',
    rights: 'All rights reserved.',
  },
  zh: {
    siteLabel: '官方网站',
    navigationLabel: '导航',
    quickLinksLabel: '快速链接',
    contactLabel: '联系',
    addressLabel: '地址',
    phoneLabel: '电话',
    emailLabel: '邮箱',
    address: '墨西哥-帕丘卡公路 87.5 公里',
    phone: '773-109-9748',
    email: 'itics@itsoeh.edu.mx',
    footnote: '专注于应用工程、真实问题与技术协作的学术空间。',
    institution: '伊达尔戈州西部高等技术学院',
    rights: '保留所有权利。',
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta name="description" content={description} />
    <!-- Hreflang for SEO -->
    {alternateLinks.map(({ code, path }) => (
      <link rel="alternate" hreflang={code} href={path} />
    ))}
    <link rel="alternate" hreflang="x-default" href={defaultPath} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 lg:px-12 py-4 bg-apple-nav backdrop-blur-md border-b border-black/5 transition-all">
      <a class="flex items-center gap-2.5 no-underline" href={`/${lang}`}>
        <Image src="/icon.png" alt="Ing. TICs" width={950} height={830} loading="eager" fetchpriority="high" class="w-[3.315rem] h-[3.315rem] object-contain" />
        <span class="font-sans font-bold text-sm tracking-tight text-apple-text leading-tight">
          <span class="block">Ingeniería en Tecnologías de la</span>
          <span class="block">Información y Comunicaciones</span>
        </span>
      </a>
      <div class="hidden md:flex relative p-1 bg-black/[0.03] rounded-full border border-black/[0.05]" id="nav-container">
        <div id="nav-pill" class="absolute top-1 bottom-1 left-0 bg-apple-blue/15 backdrop-blur-md rounded-full transition-all duration-300 ease-out z-0 opacity-0 pointer-events-none"></div>
        {navItems.map(item => {
          const isActive = currentPath === item.path || (item.path !== `/${lang}` && currentPath.startsWith(item.path));
          return (
            <a
              href={item.path}
              class={`nav-link relative z-10 px-4 py-1.5 font-sans text-xs font-semibold transition-colors duration-300 no-underline rounded-full ${isActive ? 'text-apple-blue active-nav-item' : 'text-apple-muted hover:text-apple-text'}`}
              data-active={isActive ? 'true' : 'false'}
            >
              {item.label}
            </a>
          );
        })}
      </div>
      <div class="flex items-center gap-5">
        <!-- Language switcher -->
        <div class="relative group">
          <button class="flex items-center gap-1 font-sans text-xs font-semibold text-apple-muted group-hover:text-apple-text transition-colors uppercase tracking-wider">
            {lang}
            <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          
          <div class="absolute right-0 top-full mt-2 w-32 bg-white rounded-xl shadow-lg shadow-black/5 border border-black/5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-1 group-hover:translate-y-0 z-50 overflow-hidden">
            <div class="py-1">
              {Object.entries(languages).map(([code, name]) => {
                const isActive = code === lang;
                const targetPath = currentPath.replace(`/${lang}`, `/${code}`);
                return (
                  <a 
                    href={targetPath} 
                    class={`block px-4 py-2.5 text-xs font-medium transition-colors ${isActive ? 'bg-apple-blue/5 text-apple-blue' : 'text-apple-muted hover:bg-black/5 hover:text-apple-text'}`}
                  >
                    <div class="flex items-center justify-between">
                      <span>{name}</span>
                      <span class="uppercase opacity-50 text-[10px] font-bold">{code}</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        </div>
        <a href="https://github.com/tics-itsoeh" target="_blank" rel="noopener noreferrer" class="text-apple-muted hover:text-apple-text transition-colors" title={tc('footer.github')} aria-label={tc('footer.github')}>
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
        </a>
        {!hideJoinCta && (
          <a href={`/${lang}/formacion`} class="font-sans text-xs font-medium bg-apple-blue text-white px-4 py-1.5 rounded-full hover:bg-apple-blue-hover transition-colors">{tc('cta.exploreFormation')}</a>
        )}
      </div>
    </nav>
    <slot />
    <footer class="mt-20 border-t border-black/8 bg-[#f5f5f7]">
      <div class="max-w-[1100px] mx-auto px-6 lg:px-12 pt-5 pb-8">
        <p class="text-[0.78rem] leading-relaxed text-apple-muted">
          {footerCopy[lang].footnote}
        </p>

        <div class="mt-4 h-px bg-black/8"></div>

        <div class="py-10 grid grid-cols-1 md:grid-cols-[1.5fr_1fr_1fr_1.1fr] gap-10">
          <div>
            <a class="inline-flex items-center gap-3 no-underline mb-3" href={`/${lang}`}>
              <Image src="/icon.png" alt="Ing. TICs" width={950} height={830} class="w-11 h-11 object-contain" />
              <span class="font-sans font-semibold text-[0.96rem] tracking-tight text-apple-text leading-tight">
                <span class="block">Ingeniería en Tecnologías de la</span>
                <span class="block">Información y Comunicaciones</span>
              </span>
            </a>
            <p class="text-[0.76rem] font-semibold uppercase tracking-[0.16em] text-apple-muted mb-2">{footerCopy[lang].siteLabel}</p>
            <p class="text-[0.86rem] text-apple-muted leading-relaxed max-w-md">{tc('footer.tagline')}</p>
          </div>

          <div>
            <h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-apple-muted mb-3">{footerCopy[lang].navigationLabel}</h2>
            <div class="flex flex-col gap-2">
              {navItems.map(item => (
                <a href={item.path} class="text-[0.86rem] text-apple-text/85 hover:text-apple-text transition-colors no-underline w-fit">
                  {item.label}
                </a>
              ))}
            </div>
          </div>

          <div>
            <h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-apple-muted mb-3">{footerCopy[lang].quickLinksLabel}</h2>
            <div class="flex flex-col gap-2">
              <a href={`/${lang}/formacion`} class="text-[0.86rem] text-apple-text/85 hover:text-apple-text transition-colors no-underline w-fit">{tc('cta.exploreFormation')}</a>
              <a href={`/${lang}/proyectos`} class="text-[0.86rem] text-apple-text/85 hover:text-apple-text transition-colors no-underline w-fit">{tc('cta.exploreProjects')}</a>
              <a href={`/${lang}/mentores`} class="text-[0.86rem] text-apple-text/85 hover:text-apple-text transition-colors no-underline w-fit">{tc('cta.exploreMentors')}</a>
              <a href={`/${lang}/contacto`} class="text-[0.86rem] text-apple-text/85 hover:text-apple-text transition-colors no-underline w-fit">{tc('cta.viewContact')}</a>
            </div>
          </div>

          <div>
            <h2 class="text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-apple-muted mb-3">{footerCopy[lang].contactLabel}</h2>
            <div class="flex flex-col gap-2.5 text-[0.84rem] text-apple-muted leading-relaxed">
              <p><span class="font-semibold text-apple-text/85">{footerCopy[lang].addressLabel}:</span> {footerCopy[lang].address}</p>
              <p>
                <span class="font-semibold text-apple-text/85">{footerCopy[lang].phoneLabel}:</span>
                <a href="tel:7731099748" class="text-apple-text/85 hover:text-apple-text transition-colors no-underline"> {footerCopy[lang].phone}</a>
              </p>
              <p>
                <span class="font-semibold text-apple-text/85">{footerCopy[lang].emailLabel}:</span>
                <a href={`mailto:${footerCopy[lang].email}`} class="text-apple-text/85 hover:text-apple-text transition-colors no-underline"> {footerCopy[lang].email}</a>
              </p>
              <a href="https://github.com/tics-itsoeh" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-[0.86rem] text-apple-text/85 hover:text-apple-text transition-colors no-underline w-fit pt-1">
                <svg viewBox="0 0 24 24" width="15" height="15" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                </svg>
                GitHub
              </a>
            </div>
          </div>
        </div>

        <div class="h-px bg-black/8"></div>

        <div class="pt-4 flex flex-col md:flex-row md:items-center md:justify-between gap-2 text-[0.76rem] text-apple-muted">
          <p>© {currentYear} Ing. TICs. {footerCopy[lang].rights}</p>
          <p>{footerCopy[lang].institution}</p>
        </div>
      </div>
    </footer>
    <script>
      function setupNav() {
        const container = document.getElementById('nav-container');
        const pill = document.getElementById('nav-pill');
        const links = document.querySelectorAll('.nav-link');

        if (!container || !pill || links.length === 0) return;

        let activeLink = document.querySelector('.active-nav-item') as HTMLElement;

        function movePill(el: HTMLElement) {
          if (!pill) return;
          pill.style.opacity = '1';
          pill.style.width = `${el.offsetWidth}px`;
          pill.style.transform = `translateX(${el.offsetLeft}px)`;
        }

        if (activeLink) movePill(activeLink);

        links.forEach(link => {
          link.addEventListener('mouseenter', (e) => movePill(e.target as HTMLElement));
        });

        container.addEventListener('mouseleave', () => {
          if (activeLink) movePill(activeLink);
          else pill.style.opacity = '0';
        });
      }

      setupNav();
      document.addEventListener('astro:page-load', setupNav);
    </script>
  </body>
</html>
