---
/**
 * Barra de navegación principal del sitio ITICs.
 *
 * Incluye: logo, links de navegación con pill animado,
 * selector de idioma accesible por teclado, link a GitHub,
 * CTA de admisión y menú móvil.
 */
import { Image } from 'astro:assets';
import type { UiLanguage } from '../../i18n/config';
import { languages } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';
import { resolveNavItems } from '../../data/navigation';
import { socialLinks } from '../../data/siteConfig';

interface Props {
  lang: UiLanguage;
  currentPath: string;
  hideJoinCta?: boolean;
}

const { lang, currentPath, hideJoinCta = false } = Astro.props;
const tc = useTranslations(lang, 'common');
const navItems = resolveNavItems(lang, tc);

const langSwitcherLabel: Record<UiLanguage, string> = {
  es: 'Cambiar idioma',
  en: 'Change language',
  zh: '切换语言',
};

const menuLabel: Record<UiLanguage, string> = {
  es: 'Abrir menú',
  en: 'Open menu',
  zh: '打开菜单',
};
---

<nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 sm:px-6 lg:px-12 py-3.5 sm:py-4 bg-apple-nav backdrop-blur-md border-b border-black/5 transition-all">
  <a class="flex items-center gap-2 sm:gap-2.5 no-underline min-w-0" href={`/${lang}`}>
    <Image src="/icon.png" alt="Ing. TICs" width={950} height={830} loading="eager" fetchpriority="high" class="w-[2.75rem] h-[2.75rem] sm:w-[3.315rem] sm:h-[3.315rem] object-contain flex-shrink-0" />
    <span class="hidden sm:block font-sans font-bold text-[0.72rem] sm:text-sm tracking-tight text-apple-text leading-tight truncate">
      <span class="block">Ingeniería en Tecnologías de la</span>
      <span class="block">Información y Comunicaciones</span>
    </span>
    <span class="sm:hidden font-sans font-bold text-xs tracking-tight text-apple-text whitespace-nowrap">Ing. ITICs</span>
  </a>

  {/* Desktop navigation with animated pill */}
  <div class="hidden md:flex relative p-1 bg-black/[0.03] rounded-full border border-black/[0.05]" id="nav-container">
    <div id="nav-pill" class="absolute top-1 bottom-1 left-0 bg-apple-blue/15 backdrop-blur-md rounded-full transition-all duration-300 ease-out z-0 opacity-0 pointer-events-none"></div>
    {navItems.map(item => {
      const isActive = currentPath === item.path || (item.path !== `/${lang}` && currentPath.startsWith(item.path));
      return (
        <a
          href={item.path}
          class={`nav-link relative z-10 px-4 py-1.5 font-sans text-xs font-semibold transition-colors duration-300 no-underline rounded-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-apple-blue/40 ${isActive ? 'text-apple-blue active-nav-item' : 'text-apple-muted hover:text-apple-text'}`}
          data-active={isActive ? 'true' : 'false'}
        >
          {item.label}
        </a>
      );
    })}
  </div>

  <div class="flex items-center gap-2 sm:gap-3">
    {/* Mobile menu toggle */}
    <button
      id="mobile-menu-toggle"
      class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full border border-black/10 bg-white/80 text-apple-text focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-apple-blue/40"
      aria-label={menuLabel[lang]}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>

    <div class="hidden md:flex items-center gap-5">
      {/* Language switcher — keyboard accessible */}
      <div class="relative" id="lang-switcher">
        <button
          class="flex items-center gap-1 font-sans text-xs font-semibold text-apple-muted hover:text-apple-text transition-colors uppercase tracking-wider focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-apple-blue/40 rounded-md px-1 py-0.5"
          aria-label={langSwitcherLabel[lang]}
          aria-expanded="false"
          aria-haspopup="true"
          id="lang-switcher-btn"
        >
          {lang}
          <svg class="w-3 h-3 opacity-50 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div
          id="lang-switcher-menu"
          class="absolute right-0 top-full mt-2 w-32 bg-white rounded-xl shadow-lg shadow-black/5 border border-black/5 opacity-0 invisible transition-all duration-200 transform translate-y-1 z-50 overflow-hidden"
          role="menu"
          aria-labelledby="lang-switcher-btn"
        >
          <div class="py-1">
            {Object.entries(languages).map(([code, name]) => {
              const isActive = code === lang;
              const targetPath = currentPath.replace(`/${lang}`, `/${code}`);
              return (
                <a
                  href={targetPath}
                  role="menuitem"
                  class={`block px-4 py-2.5 text-xs font-medium transition-colors focus-visible:outline-none focus-visible:bg-apple-blue/5 ${isActive ? 'bg-apple-blue/5 text-apple-blue' : 'text-apple-muted hover:bg-black/5 hover:text-apple-text'}`}
                >
                  <div class="flex items-center justify-between">
                    <span>{name}</span>
                    <span class="uppercase opacity-50 text-[10px] font-bold">{code}</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </div>

      {/* GitHub link */}
      <a href={socialLinks.github} target="_blank" rel="noopener noreferrer" class="text-apple-muted hover:text-apple-text transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-apple-blue/40 rounded-md" title={tc('footer.github')} aria-label={tc('footer.github')}>
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
      </a>

      {/* CTA de admisión */}
      {!hideJoinCta && (
        <a href={`/${lang}/unirse`} class="font-sans text-xs font-medium bg-apple-blue text-white px-4 py-1.5 rounded-full hover:bg-apple-blue-hover transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-apple-blue/40 focus-visible:ring-offset-2">{tc('cta.admission2026')}</a>
      )}
    </div>
  </div>

  {/* Mobile menu */}
  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 right-0 border-t border-black/5 bg-[#fbfbfd]/95 backdrop-blur-xl shadow-[0_10px_30px_rgba(0,0,0,0.06)]">
    <div class="px-4 sm:px-6 py-4 space-y-3">
      <div class="grid grid-cols-2 gap-2">
        {navItems.map((item) => {
          const isActive = currentPath === item.path || (item.path !== `/${lang}` && currentPath.startsWith(item.path));
          return (
            <a
              href={item.path}
              class={`px-3 py-2 rounded-lg text-sm font-semibold border transition-colors ${isActive ? 'bg-apple-blue/10 text-apple-blue border-apple-blue/20' : 'bg-white text-apple-text border-black/10 hover:bg-black/[0.03]'}`}
            >
              {item.label}
            </a>
          );
        })}
      </div>

      <div class="grid grid-cols-3 gap-2 border-t border-black/8 pt-3">
        {Object.entries(languages).map(([code, name]) => {
          const isActive = code === lang;
          const targetPath = currentPath.replace(`/${lang}`, `/${code}`);
          return (
            <a href={targetPath} class={`px-3 py-2 rounded-lg text-xs font-semibold text-center uppercase border transition-colors ${isActive ? 'bg-apple-blue/10 text-apple-blue border-apple-blue/20' : 'bg-white text-apple-text border-black/10 hover:bg-black/[0.03]'}`}>
              {name}
            </a>
          );
        })}
      </div>

      <div class="flex flex-col gap-2 border-t border-black/8 pt-3">
        <a
          href={socialLinks.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-4 py-3 rounded-full border border-black/10 bg-white text-apple-text text-sm font-semibold hover:bg-black/[0.03] transition-colors"
        >
          {tc('footer.github')}
        </a>
        {!hideJoinCta && (
          <a
            href={`/${lang}/unirse`}
            class="inline-flex items-center justify-center px-4 py-3 rounded-full bg-apple-blue text-white text-sm font-semibold hover:bg-apple-blue-hover transition-colors"
          >
            {tc('cta.admission2026')}
          </a>
        )}
      </div>
    </div>
  </div>
</nav>
