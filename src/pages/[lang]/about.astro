---
import Layout from '../../layouts/Layout.astro';
import type { UiLanguage } from '../../i18n/config';
import { languages } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const tc = useTranslations(lang, 'common');
const t = useTranslations(lang, 'about');
const creditCards = ['web', 'content', 'review', 'identity'] as const;
---

<Layout lang={lang} title={tc('nav.about')}>
  <main class="bg-apple-surface min-h-screen pt-32 pb-24 text-apple-text overflow-x-hidden">
    <section class="max-w-[980px] mx-auto px-5 sm:px-8 mb-16 text-center">
      <h1 class="text-[clamp(3rem,6vw,5rem)] font-black tracking-tight leading-[1] mb-6">{t('hero.title')}</h1>
      <p class="text-[1.15rem] md:text-[1.3rem] text-apple-muted font-medium leading-relaxed max-w-[860px] mx-auto">
        {t('hero.subtitle')}
      </p>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('creator.title')}</h2>

      <div class="mt-8 max-w-[340px]">
        <article class="group relative overflow-hidden rounded-[1.6rem] border border-apple-border/85 bg-apple-surface/70 p-4 sm:p-5 shadow-[0_10px_28px_rgba(15,23,42,0.04)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(15,23,42,0.08)]">
          <div class="pointer-events-none absolute inset-x-0 top-0 h-10 bg-gradient-to-b from-white/55 to-transparent"></div>
          <div class="aspect-[4/5] w-[91%] mx-auto overflow-hidden rounded-3xl bg-apple-surface shadow-sm">
            <img
              src="/mentors/students/josepo.webp"
              alt={t('creator.name')}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="mt-5">
            <div class="mb-3 inline-flex items-center rounded-full border border-apple-border-strong bg-white/85 px-2.5 py-1 text-[0.7rem] font-bold uppercase tracking-[0.08em] text-apple-muted">
              {t('creator.meta')}
            </div>
            <h3 class="text-[1.55rem] font-bold tracking-tight leading-tight">{t('creator.name')}</h3>
            <p class="mt-2 text-[0.95rem] text-apple-muted font-medium leading-relaxed">{t('creator.role')}</p>

            <div class="mt-4 flex flex-wrap gap-2">
              {['tag1', 'tag2', 'tag3'].map((tag) => (
                <span class="px-3 py-1 bg-apple-surface text-[0.76rem] font-semibold rounded-lg text-apple-text">
                  {t(`creator.${tag}`)}
                </span>
              ))}
            </div>

            <div class="mt-6 border-t border-apple-border pt-5 flex items-center justify-between gap-3">
              <p class="inline-flex items-center gap-2 text-[0.9rem] text-apple-text font-semibold">
                <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77 5.44 5.44 0 0 0 3.5 8.52c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                </svg>
                {t('creator.github')}
              </p>
              <a href={`/${lang}/mentores/jose-manuel`} class="inline-flex items-center gap-2 text-[0.98rem] font-semibold text-apple-blue hover:underline hover:underline-offset-4">
                {t('creator.profileCta')} <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 mb-24 border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(1.9rem,3.4vw,2.7rem)] font-bold tracking-tight">{t('credits.title')}</h2>
      <p class="mt-4 text-[1.03rem] text-apple-muted font-medium leading-relaxed max-w-[940px]">{t('credits.subtitle')}</p>

      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-5">
        {creditCards.map((card) => (
          <article class="rounded-2xl border border-apple-border bg-apple-surface-alt p-6">
            <p class="text-[0.72rem] uppercase tracking-[0.16em] font-semibold text-apple-muted">{t(`credits.cards.${card}.title`)}</p>
            <p class="mt-3 text-[0.98rem] font-semibold leading-relaxed text-apple-text">{t(`credits.cards.${card}.value`)}</p>
          </article>
        ))}
      </div>

      <article class="mt-6 rounded-2xl border border-dashed border-black/15 bg-apple-surface p-6">
        <h3 class="text-[1rem] font-bold tracking-tight">{t('updating.title')}</h3>
        <p class="mt-2 text-[0.95rem] text-apple-muted font-medium leading-relaxed">{t('updating.body')}</p>
      </article>
    </section>
  </main>
</Layout>
