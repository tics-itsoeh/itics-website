---
import '../styles/global.css';
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { UiLanguage } from '../i18n/config';
import { languages } from '../i18n/config';

interface Props {
  title?: string;
  description?: string;
  lang?: UiLanguage;
  hideJoinCta?: boolean;
}

const lang: UiLanguage = Astro.props.lang ?? getLangFromUrl(Astro.url);
const tc = useTranslations(lang, 'common');

const {
  title = tc('nav.home'),
  description = tc('footer.tagline'),
  hideJoinCta = false,
} = Astro.props;
const pageTitle = String(title).trim() || tc('nav.home');
const fullTitle = `Ing. TICs - ${pageTitle}`;

const currentPath = Astro.url.pathname;

const navItems = [
  { path: `/${lang}`,           label: tc('nav.home')     },
  { path: `/${lang}/formacion`, label: tc('nav.formation') },
  { path: `/${lang}/unirse`,    label: tc('nav.join')      },
  { path: `/${lang}/proyectos`,  label: tc('nav.projects') },
  { path: `/${lang}/mentores`,   label: tc('nav.mentors')  },
  { path: `/${lang}/contacto`,   label: tc('nav.contact')  },
];

// Alternate lang hrefs for <link rel="alternate"> — good for SEO
const alternateLinks = Object.keys(languages).map(code => ({
  code,
  path: currentPath.replace(`/${lang}`, `/${code}`)
}));
const defaultPath = `/es${currentPath.replace(`/${lang}`, '')}`;
const currentYear = new Date().getFullYear();

const footerCopy: Record<UiLanguage, {
  navigationLabel: string;
  quickLinksLabel: string;
  contactLabel: string;
  phoneLabel: string;
  whatsappLabel: string;
  programLine: string;
  campusLine: string;
  admissionLabel: string;
  studyPlanLabel: string;
  githubProjectsLabel: string;
  roboticsClubLabel: string;
  certificationsLabel: string;
  phone: string;
  whatsapp: string;
  email: string;
  instagramLabel: string;
  facebookLabel: string;
  tiktokLabel: string;
  githubLabel: string;
  instagramUrl: string;
  facebookUrl: string;
  tiktokUrl: string;
  githubUrl: string;
  phoneUrl: string;
  whatsappUrl: string;
  emailUrl: string;
  rights: string;
}> = {
  es: {
    navigationLabel: 'Navegación',
    quickLinksLabel: 'Enlaces rápidos',
    contactLabel: 'Contacto',
    phoneLabel: 'Teléfono',
    whatsappLabel: 'WhatsApp',
    programLine: 'Ingeniería en Tecnologías de la Información y Comunicaciones',
    campusLine: 'Tecnológico Nacional de México campus Occidente del Estado de Hidalgo',
    admissionLabel: 'Admisión 2026',
    studyPlanLabel: 'Plan de estudios',
    githubProjectsLabel: 'GitHub TICs',
    roboticsClubLabel: 'Club de Robótica',
    certificationsLabel: 'Certificaciones',
    phone: '772 139 7096',
    whatsapp: '+52 1 773 109 9748',
    email: 'tics@itsoeh.edu.mx',
    instagramLabel: 'Instagram',
    facebookLabel: 'Facebook',
    tiktokLabel: 'TikTok',
    githubLabel: 'GitHub',
    instagramUrl: 'https://www.instagram.com/itics.itsoeh',
    facebookUrl: 'https://www.facebook.com/ITIC.ITSOEHmx',
    tiktokUrl: 'https://www.tiktok.com/@ing.tics',
    githubUrl: 'https://github.com/tics-itsoeh',
    phoneUrl: 'tel:+527721397096',
    whatsappUrl: 'https://wa.me/5217731099748',
    emailUrl: 'mailto:tics@itsoeh.edu.mx',
    rights: 'Todos los derechos reservados.',
  },
  en: {
    navigationLabel: 'Navigation',
    quickLinksLabel: 'Quick links',
    contactLabel: 'Contact',
    phoneLabel: 'Phone',
    whatsappLabel: 'WhatsApp',
    programLine: 'Information and Communications Technology Engineering',
    campusLine: 'Tecnológico Nacional de México, Western Hidalgo Campus',
    admissionLabel: 'Admission 2026',
    studyPlanLabel: 'Study plan',
    githubProjectsLabel: 'TICs GitHub',
    roboticsClubLabel: 'Robotics Club',
    certificationsLabel: 'Certifications',
    phone: '772 139 7096',
    whatsapp: '+52 1 773 109 9748',
    email: 'tics@itsoeh.edu.mx',
    instagramLabel: 'Instagram',
    facebookLabel: 'Facebook',
    tiktokLabel: 'TikTok',
    githubLabel: 'GitHub',
    instagramUrl: 'https://www.instagram.com/itics.itsoeh',
    facebookUrl: 'https://www.facebook.com/ITIC.ITSOEHmx',
    tiktokUrl: 'https://www.tiktok.com/@ing.tics',
    githubUrl: 'https://github.com/tics-itsoeh',
    phoneUrl: 'tel:+527721397096',
    whatsappUrl: 'https://wa.me/5217731099748',
    emailUrl: 'mailto:tics@itsoeh.edu.mx',
    rights: 'All rights reserved.',
  },
  zh: {
    navigationLabel: '导航',
    quickLinksLabel: '快速链接',
    contactLabel: '联系',
    phoneLabel: '电话',
    whatsappLabel: 'WhatsApp',
    programLine: '信息与通信技术工程',
    campusLine: '墨西哥国家技术学院 伊达尔戈州西部校区',
    admissionLabel: '2026 招生',
    studyPlanLabel: '培养方案',
    githubProjectsLabel: 'TICs GitHub',
    roboticsClubLabel: '机器人社团',
    certificationsLabel: '认证体系',
    phone: '772 139 7096',
    whatsapp: '+52 1 773 109 9748',
    email: 'tics@itsoeh.edu.mx',
    instagramLabel: 'Instagram',
    facebookLabel: 'Facebook',
    tiktokLabel: 'TikTok',
    githubLabel: 'GitHub',
    instagramUrl: 'https://www.instagram.com/itics.itsoeh',
    facebookUrl: 'https://www.facebook.com/ITIC.ITSOEHmx',
    tiktokUrl: 'https://www.tiktok.com/@ing.tics',
    githubUrl: 'https://github.com/tics-itsoeh',
    phoneUrl: 'tel:+527721397096',
    whatsappUrl: 'https://wa.me/5217731099748',
    emailUrl: 'mailto:tics@itsoeh.edu.mx',
    rights: '保留所有权利。',
  },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta name="description" content={description} />
    <!-- Hreflang for SEO -->
    {alternateLinks.map(({ code, path }) => (
      <link rel="alternate" hreflang={code} href={path} />
    ))}
    <link rel="alternate" hreflang="x-default" href={defaultPath} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style is:global>
      body.is-loading {
        overflow: hidden;
      }

      .site-loader {
        position: fixed;
        inset: 0;
        z-index: 200;
        display: grid;
        place-items: center;
        background:
          radial-gradient(circle at 50% 30%, rgba(255, 255, 255, 0.94), rgba(245, 245, 247, 0.97) 60%),
          #f5f5f7;
        opacity: 1;
        visibility: visible;
        transition: opacity 420ms ease, visibility 420ms ease;
      }

      .site-loader--hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .site-loader__inner {
        display: grid;
        justify-items: center;
        gap: 1rem;
        transform: translateY(-4%);
      }

      .site-loader__logo {
        width: clamp(7rem, 14vw, 11rem);
        height: auto;
        filter: drop-shadow(0 14px 28px rgba(30, 40, 124, 0.22));
        transform-origin: center;
        animation: loader-pulse 1.8s ease-in-out infinite;
      }

      .site-loader__line {
        width: clamp(8.5rem, 20vw, 11.5rem);
        height: 2px;
        border-radius: 999px;
        overflow: hidden;
        background: rgba(29, 29, 31, 0.12);
      }

      .site-loader__line::before {
        content: "";
        display: block;
        width: 40%;
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #1e287c 0%, #0066cc 100%);
        animation: loader-line 1.3s ease-in-out infinite;
      }

      @keyframes loader-pulse {
        0%, 100% {
          transform: scale(0.95);
          opacity: 0.85;
        }
        50% {
          transform: scale(1);
          opacity: 1;
        }
      }

      @keyframes loader-line {
        0% {
          transform: translateX(-115%);
        }
        100% {
          transform: translateX(290%);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .site-loader__logo,
        .site-loader__line::before {
          animation: none;
        }
      }
    </style>
  </head>
  <body>
    <div id="site-loader" class="site-loader site-loader--hidden" aria-hidden="true">
      <div class="site-loader__inner">
        <img
          src="/logos/logo.svg"
          alt=""
          width="999"
          height="1002"
          class="site-loader__logo"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <span class="site-loader__line"></span>
      </div>
    </div>
    <noscript>
      <style>
        body {
          overflow: auto !important;
        }
        #site-loader {
          display: none !important;
        }
      </style>
    </noscript>
    <nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 sm:px-6 lg:px-12 py-3.5 sm:py-4 bg-apple-nav backdrop-blur-md border-b border-black/5 transition-all">
      <a class="flex items-center gap-2 sm:gap-2.5 no-underline min-w-0" href={`/${lang}`}>
        <Image src="/icon.png" alt="Ing. TICs" width={950} height={830} loading="eager" fetchpriority="high" class="w-[2.75rem] h-[2.75rem] sm:w-[3.315rem] sm:h-[3.315rem] object-contain flex-shrink-0" />
        <span class="hidden sm:block font-sans font-bold text-[0.72rem] sm:text-sm tracking-tight text-apple-text leading-tight truncate">
          <span class="block">Ingeniería en Tecnologías de la</span>
          <span class="block">Información y Comunicaciones</span>
        </span>
        <span class="sm:hidden font-sans font-bold text-xs tracking-tight text-apple-text whitespace-nowrap">Ing. ITICs</span>
      </a>
      <div class="hidden md:flex relative p-1 bg-black/[0.03] rounded-full border border-black/[0.05]" id="nav-container">
        <div id="nav-pill" class="absolute top-1 bottom-1 left-0 bg-apple-blue/15 backdrop-blur-md rounded-full transition-all duration-300 ease-out z-0 opacity-0 pointer-events-none"></div>
        {navItems.map(item => {
          const isActive = currentPath === item.path || (item.path !== `/${lang}` && currentPath.startsWith(item.path));
          return (
            <a
              href={item.path}
              class={`nav-link relative z-10 px-4 py-1.5 font-sans text-xs font-semibold transition-colors duration-300 no-underline rounded-full ${isActive ? 'text-apple-blue active-nav-item' : 'text-apple-muted hover:text-apple-text'}`}
              data-active={isActive ? 'true' : 'false'}
            >
              {item.label}
            </a>
          );
        })}
      </div>
      <div class="flex items-center gap-2 sm:gap-3">
        <button
          id="mobile-menu-toggle"
          class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full border border-black/10 bg-white/80 text-apple-text"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </button>

        <div class="hidden md:flex items-center gap-5">
          <!-- Language switcher -->
          <div class="relative group">
            <button class="flex items-center gap-1 font-sans text-xs font-semibold text-apple-muted group-hover:text-apple-text transition-colors uppercase tracking-wider">
              {lang}
              <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            
            <div class="absolute right-0 top-full mt-2 w-32 bg-white rounded-xl shadow-lg shadow-black/5 border border-black/5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-1 group-hover:translate-y-0 z-50 overflow-hidden">
              <div class="py-1">
                {Object.entries(languages).map(([code, name]) => {
                  const isActive = code === lang;
                  const targetPath = currentPath.replace(`/${lang}`, `/${code}`);
                  return (
                    <a 
                      href={targetPath} 
                      class={`block px-4 py-2.5 text-xs font-medium transition-colors ${isActive ? 'bg-apple-blue/5 text-apple-blue' : 'text-apple-muted hover:bg-black/5 hover:text-apple-text'}`}
                    >
                      <div class="flex items-center justify-between">
                        <span>{name}</span>
                        <span class="uppercase opacity-50 text-[10px] font-bold">{code}</span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </div>
          </div>
          <a href="https://github.com/tics-itsoeh" target="_blank" rel="noopener noreferrer" class="text-apple-muted hover:text-apple-text transition-colors" title={tc('footer.github')} aria-label={tc('footer.github')}>
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
          </a>
          {!hideJoinCta && (
            <a href={`/${lang}/unirse`} class="font-sans text-xs font-medium bg-apple-blue text-white px-4 py-1.5 rounded-full hover:bg-apple-blue-hover transition-colors">{tc('cta.admission2026')}</a>
          )}
        </div>
      </div>

      <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 right-0 border-t border-black/5 bg-[#fbfbfd]/95 backdrop-blur-xl shadow-[0_10px_30px_rgba(0,0,0,0.06)]">
        <div class="px-4 sm:px-6 py-4 space-y-3">
          <div class="grid grid-cols-2 gap-2">
            {navItems.map((item) => {
              const isActive = currentPath === item.path || (item.path !== `/${lang}` && currentPath.startsWith(item.path));
              return (
                <a
                  href={item.path}
                  class={`px-3 py-2 rounded-lg text-sm font-semibold border transition-colors ${isActive ? 'bg-apple-blue/10 text-apple-blue border-apple-blue/20' : 'bg-white text-apple-text border-black/10 hover:bg-black/[0.03]'}`}
                >
                  {item.label}
                </a>
              );
            })}
          </div>

          <div class="grid grid-cols-3 gap-2 border-t border-black/8 pt-3">
            {Object.entries(languages).map(([code, name]) => {
              const isActive = code === lang;
              const targetPath = currentPath.replace(`/${lang}`, `/${code}`);
              return (
                <a href={targetPath} class={`px-3 py-2 rounded-lg text-xs font-semibold text-center uppercase border transition-colors ${isActive ? 'bg-apple-blue/10 text-apple-blue border-apple-blue/20' : 'bg-white text-apple-text border-black/10 hover:bg-black/[0.03]'}`}>
                  {name}
                </a>
              );
            })}
          </div>

          <div class="flex flex-col gap-2 border-t border-black/8 pt-3">
            <a
              href="https://github.com/tics-itsoeh"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-4 py-3 rounded-full border border-black/10 bg-white text-apple-text text-sm font-semibold hover:bg-black/[0.03] transition-colors"
            >
              {tc('footer.github')}
            </a>
            {!hideJoinCta && (
              <a
                href={`/${lang}/unirse`}
                class="inline-flex items-center justify-center px-4 py-3 rounded-full bg-apple-blue text-white text-sm font-semibold hover:bg-apple-blue-hover transition-colors"
              >
                {tc('cta.admission2026')}
              </a>
            )}
          </div>
        </div>
      </div>
    </nav>
    <div id="page-scroll-content">
      <slot />
      <footer class="mt-20 border-t border-black/8 bg-[#f5f5f7]">
      <div class="max-w-[1200px] mx-auto px-6 lg:px-12 pt-12 pb-8">
        <div class="flex flex-wrap items-center justify-center lg:justify-between gap-x-10 gap-y-8">
          <img src="/logos/educacion.png" alt="Educación" width="255" height="105" loading="lazy" decoding="async" class="h-[3rem] sm:h-[3.75rem] w-auto object-contain opacity-95" />
          <img src="/logos/tecnm.png" alt="TecNM" width="255" height="105" loading="lazy" decoding="async" class="h-[3rem] sm:h-[3.75rem] w-auto object-contain opacity-95" />
          <img src="/logos/itsoeh.png" alt="ITSOEH" width="255" height="105" loading="lazy" decoding="async" class="h-[3rem] sm:h-[3.75rem] w-auto object-contain opacity-95" />
          <img src="/logos/tics.png" alt="TICs" width="255" height="105" loading="lazy" decoding="async" class="h-[3rem] sm:h-[3.75rem] w-auto object-contain opacity-95" />
          <img src="/logos/esparco.png" alt="Esparco" width="255" height="105" loading="lazy" decoding="async" class="h-[3rem] sm:h-[3.75rem] w-auto object-contain opacity-95" />
        </div>

        <div class="text-center mt-10">
          <p class="text-[1.08rem] md:text-[1.2rem] font-semibold tracking-tight text-apple-text leading-relaxed">{footerCopy[lang].programLine}</p>
          <p class="text-[0.92rem] text-apple-muted font-normal mt-2">{footerCopy[lang].campusLine}</p>
        </div>

        <div class="mt-10 h-px bg-black/8"></div>

        <div class="py-10 grid grid-cols-1 md:grid-cols-3 gap-0">
          <div class="pb-8 md:pb-0">
            <h2 class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-apple-muted mb-4">{footerCopy[lang].navigationLabel}</h2>
            <div class="flex flex-col gap-2.5">
              <a href={`/${lang}`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{tc('nav.home')}</a>
              <a href={`/${lang}/formacion`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{tc('nav.formation')}</a>
              <a href={`/${lang}/unirse`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{tc('nav.join')}</a>
              <a href={`/${lang}/proyectos`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{tc('nav.projects')}</a>
              <a href={`/${lang}/mentores`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{tc('nav.mentors')}</a>
              <a href={`/${lang}/contacto`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{tc('nav.contact')}</a>
            </div>
          </div>

          <div class="border-t border-black/8 md:border-t-0 md:border-l md:border-black/8 pt-8 md:pt-0 md:pl-10 pb-8 md:pb-0">
            <h2 class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-apple-muted mb-4">{footerCopy[lang].quickLinksLabel}</h2>
            <div class="flex flex-col gap-2.5">
              <a href={`/${lang}/unirse`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{footerCopy[lang].admissionLabel}</a>
              <a href={`/${lang}/formacion#plan-estudios`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{footerCopy[lang].studyPlanLabel}</a>
              <a href={footerCopy[lang].githubUrl} target="_blank" rel="noopener noreferrer" class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{footerCopy[lang].githubProjectsLabel}</a>
              <a href={`/${lang}/mentores`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{footerCopy[lang].roboticsClubLabel}</a>
              <a href={`/${lang}/formacion`} class="text-[0.88rem] font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{footerCopy[lang].certificationsLabel}</a>
            </div>
          </div>

          <div class="border-t border-black/8 md:border-t-0 md:border-l md:border-black/8 pt-8 md:pt-0 md:pl-10">
            <h2 class="text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-apple-muted mb-4">{footerCopy[lang].contactLabel}</h2>
            <div class="flex flex-col gap-2.5 text-[0.88rem] text-apple-muted leading-relaxed">
              <a href={footerCopy[lang].emailUrl} class="font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{footerCopy[lang].email}</a>
              <a href={footerCopy[lang].phoneUrl} class="font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{footerCopy[lang].phone}</a>
              <a href={footerCopy[lang].whatsappUrl} target="_blank" rel="noopener noreferrer" class="font-normal text-apple-text/80 hover:text-apple-text transition-colors no-underline w-fit">{footerCopy[lang].whatsappLabel}: {footerCopy[lang].whatsapp}</a>

              <div class="mt-3 flex flex-wrap items-center gap-2">
