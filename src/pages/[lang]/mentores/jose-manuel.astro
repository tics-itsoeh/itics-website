---
import Layout from '../../../layouts/Layout.astro';
import type { UiLanguage } from '../../../i18n/config';
import { languages } from '../../../i18n/config';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const t = useTranslations(lang, 'mentors');
const tc = useTranslations(lang, 'common');
---

<Layout lang={lang} title={`${tc('nav.mentors')} · ${t('profile.name')}`}>
  <main class="bg-apple-bg pt-32 pb-24 min-h-screen">
    <div class="max-w-[1040px] mx-auto px-5 sm:px-8">
      <a
        href={`/${lang}/mentores`}
        class="inline-flex items-center gap-2 text-sm font-medium text-apple-muted hover:text-apple-text transition-colors mb-12"
      >
        <span aria-hidden="true">&larr;</span>
        {t('profile.back')}
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-[340px_1fr] gap-10 lg:gap-14 items-start">
        <aside>
          <div class="aspect-[4/5] w-full overflow-hidden rounded-3xl bg-[#f5f5f7] mb-6 relative shadow-sm">
            <img
              src="/mentors/josepo.png"
              alt={t('profile.name')}
              class="w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 ring-1 ring-inset ring-black/5 rounded-3xl pointer-events-none"></div>
          </div>

          <div class="flex flex-col gap-3">
            <a
              href="https://github.com/deepdevjose"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between px-4 py-3 bg-white rounded-xl border border-black/5 hover:border-apple-blue/50 transition-all"
            >
              <span class="text-[0.85rem] font-semibold text-apple-text">GitHub</span>
              <span class="text-[0.78rem] font-semibold text-apple-muted">@deepdevjose</span>
            </a>
            <a
              href="https://www.linkedin.com/in/deepdevjose/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between px-4 py-3 bg-white rounded-xl border border-black/5 hover:border-apple-blue/50 transition-all"
            >
              <span class="text-[0.85rem] font-semibold text-apple-text">LinkedIn</span>
              <span class="text-[0.78rem] font-semibold text-apple-muted">deepdevjose</span>
            </a>
            <a
              href="https://deepdev-portfolio.vercel.app"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between px-4 py-3 bg-white rounded-xl border border-black/5 hover:border-apple-blue/50 transition-all"
            >
              <span class="text-[0.85rem] font-semibold text-apple-text">Portfolio</span>
              <span class="text-[0.78rem] font-semibold text-apple-muted">web</span>
            </a>
          </div>
        </aside>

        <section>
          <h1 class="text-4xl lg:text-5xl font-black tracking-tight text-apple-text mb-4">{t('profile.name')}</h1>
          <p class="text-xl font-medium text-apple-muted mb-8">{t('profile.role')}</p>

          <div class="flex flex-wrap gap-2 mb-10">
            {['tag1', 'tag2', 'tag3', 'tag4'].map((tag) => (
              <span class="text-sm font-semibold px-4 py-1.5 bg-black/5 text-apple-text rounded-md tracking-wide">
                {t(`profile.${tag}`)}
              </span>
            ))}
          </div>

          <div class="prose prose-lg prose-apple max-w-none text-apple-text leading-relaxed mb-14">
            <p class="mb-4">{t('profile.bio1')}</p>
            <p>{t('profile.bio2')}</p>
          </div>

          <div class="mb-14 border-t border-black/5 pt-8">
            <h2 class="text-sm font-bold tracking-widest uppercase text-apple-muted mb-5">{t('profile.academicTitle')}</h2>
            <div class="flex flex-col gap-4">
              <div class="rounded-2xl border border-black/5 bg-white p-5">
                <p class="text-[0.94rem] font-bold text-apple-text leading-tight mb-1">{t('profile.degreeTitle')}</p>
                <p class="text-[0.84rem] font-medium text-apple-muted">{t('profile.degreeInstitution')}</p>
              </div>
              <div class="rounded-2xl border border-black/5 bg-white p-5">
                <p class="text-[0.94rem] font-bold text-apple-text leading-tight mb-1">{t('profile.researchTitle')}</p>
                <p class="text-[0.84rem] font-medium text-apple-muted">{t('profile.researchInstitution')}</p>
              </div>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold tracking-tight text-apple-text mb-6">{t('profile.contributionsTitle')}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <a
                href={`/${lang}/proyectos#evidencias`}
                class="flex flex-col h-full p-5 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-md hover:border-apple-blue/30 transition-all group"
              >
                <h3 class="font-bold text-apple-text group-hover:text-apple-blue transition-colors mb-2">{t('profile.communityTitle')}</h3>
                <p class="text-[0.92rem] font-medium text-apple-muted leading-relaxed">{t('profile.communityDesc')}</p>
              </a>
              <a
                href="https://github.com/deepdevjose"
                target="_blank"
                rel="noopener noreferrer"
                class="flex flex-col h-full p-5 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-md hover:border-apple-blue/30 transition-all group"
              >
                <h3 class="font-bold text-apple-text group-hover:text-apple-blue transition-colors mb-2">{t('profile.relatedTitle')}</h3>
                <p class="text-[0.92rem] font-medium text-apple-muted leading-relaxed">{t('profile.relatedDesc')}</p>
              </a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>
