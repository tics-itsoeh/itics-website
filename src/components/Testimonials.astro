---
import type { UiLanguage } from '../i18n/config';

interface Props {
  lang: UiLanguage;
}

const { lang } = Astro.props;

// For now, providing localized dummy data directly in the component.
// In the future, this can be moved to the i18n JSON files if required.
const translations = {
  es: {
    title: 'Lo que dice nuestra comunidad',
    subtitle: 'Historias reales de estudiantes, egresados y aliados de la industria.',
    testimonials: [
      {
        quote: 'La carrera me dio las bases fundamentales en programación, y hoy desarrollo software para miles de usuarios. La atención de los docentes es excepcional.',
        author: 'Alejandro Martínez',
        role: 'Egresado, Ing. de Software',
        initial: 'A'
      },
      {
        quote: 'Gracias a los clubes de robótica, pude poner en práctica lo que aprendimos en clase e ir a competencias nacionales. Es una comunidad increíble.',
        author: 'Sofía Reyes',
        role: 'Estudiante de 6to Semestre',
        initial: 'S'
      },
      {
        quote: 'Como empresa de la región, los ingenieros egresados de ITSOEH han demostrado un gran nivel resolviendo problemas complejos de infraestructura.',
        author: 'Carlos Gómez',
        role: 'Aliado Industrial',
        initial: 'C'
      }
    ]
  },
  en: {
    title: 'What our community says',
    subtitle: 'Real stories from students, alumni, and industry partners.',
    testimonials: [
      {
        quote: 'The program gave me the fundamental programming skills, and today I develop software for thousands of users. The faculty support is exceptional.',
        author: 'Alejandro Martínez',
        role: 'Alumnus, Software Eng.',
        initial: 'A'
      },
      {
        quote: 'Thanks to the robotics clubs, I could put into practice what we learned in class and go to national competitions. It is an amazing community.',
        author: 'Sofía Reyes',
        role: '6th Semester Student',
        initial: 'S'
      },
      {
        quote: 'As a local company, engineers graduating from ITSOEH have shown a great level in solving complex infrastructure problems.',
        author: 'Carlos Gómez',
        role: 'Industry Partner',
        initial: 'C'
      }
    ]
  },
  zh: {
    title: '我们社区的心声',
    subtitle: '来自学生、校友和行业合作伙伴的真实故事。',
    testimonials: [
      {
        quote: '该项目为我提供了基本的编程技能，如今我为成千上万的用户开发软件。老师们的支持非常出色。',
        author: '亚历杭德罗 (Alejandro)',
        role: '校友，软件工程师',
        initial: 'A'
      },
      {
        quote: '多亏了机器人俱乐部，我才能将课堂上学到的知识付诸实践，并参加全国比赛。这是一个了不起的社区。',
        author: '索菲亚 (Sofía)',
        role: '第六学期学生',
        initial: 'S'
      },
      {
        quote: '作为当地企业，从ITSOEH毕业的工程师在解决复杂基础设施问题方面表现出极高的水平。',
        author: '卡洛斯 (Carlos)',
        role: '行业合作伙伴',
        initial: 'C'
      }
    ]
  }
};

const content = translations[lang] || translations['es'];
---

<section class="max-w-[1200px] mx-auto px-5 sm:px-8 pb-20 md:pb-32 border-t border-apple-border pt-14 md:pt-20">
  <div class="mb-14 text-center md:text-left">
    <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-4">{content.title}</h2>
    <p class="text-[1.15rem] text-apple-muted font-medium leading-relaxed max-w-[720px]">
      {content.subtitle}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {content.testimonials.map((t) => (
      <article class="bg-apple-surface-alt rounded-[2rem] p-8 border border-apple-border hover:shadow-lg hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between group">
        <div>
          <svg class="w-8 h-8 text-apple-blue opacity-50 mb-6 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
          </svg>
          <p class="text-[1.05rem] text-apple-text font-medium leading-relaxed mb-8">
            "{t.quote}"
          </p>
        </div>
        <div class="flex items-center gap-4 border-t border-apple-border-strong pt-6">
          <div class="w-12 h-12 rounded-full bg-apple-blue text-white flex items-center justify-center font-bold text-lg shadow-inner">
            {t.initial}
          </div>
          <div>
            <h3 class="text-[1rem] font-bold text-apple-text leading-tight">{t.author}</h3>
            <p class="text-[0.85rem] text-apple-muted font-semibold mt-0.5">{t.role}</p>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
