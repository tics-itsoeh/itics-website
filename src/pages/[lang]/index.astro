---
/**
 * Página principal (Home) del sitio ITICs.
 *
 * Arquitectura y Estrategia:
 * - Funciona como un "Hub" o "Landing" que resume los puntos clave de la carrera.
 * - No profundiza en detalles técnicos, sino que dirige al usuario a las páginas 
 *   internas correspondientes (Formación, Proyectos, Mentores).
 * - Está diseñada como un embudo (funnel) que termina con llamadas a la acción (CTAs) 
 *   para captar aspirantes o establecer contacto.
 */
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Testimonials from '../../components/Testimonials.astro';
import type { UiLanguage } from '../../i18n/config';
import { languages } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const tc = useTranslations(lang, 'common');
const th = useTranslations(lang, 'home');
const tco = useTranslations(lang, 'contact');
const phoneUrl = tco('values.phoneUrl');
const whatsappUrl = tco('values.whatsappUrl');
const emailUrl = tco('values.emailUrl');
const instagramUrl = tco('values.instagramUrl');
const mapEmbedSrc = 'https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d2225.737312900873!2d-99.22126109580296!3d20.20515199712743!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e1!3m2!1ses-419!2smx!4v1777439045268!5m2!1ses-419!2smx';
---

<Layout lang={lang} title={tc('nav.home')}>
  <!-- Hero -->
  <Hero lang={lang} />

  <main class="bg-apple-surface text-apple-text overflow-x-hidden">

    <!-- More Than Classes -->
    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 py-20 md:py-32 border-t border-apple-border">
      <div class="bg-apple-surface-alt rounded-[2.5rem] p-6 sm:p-10 md:p-16 border border-apple-border">
        <div class="max-w-[580px] mb-16">
          <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-4">
            {th('formation.title')}
          </h2>
          <p class="text-[1.15rem] text-apple-muted font-medium leading-relaxed">
            {th('formation.subtitle')}
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            { key: 'formation.realAccess' },
            { key: 'formation.building' },
            { key: 'formation.collaboration' },
          ].map(({ key }) => (
            <div class="bg-apple-surface rounded-2xl p-7 border border-apple-border shadow-sm hover:shadow-md transition-shadow">
              <h3 class="text-lg font-bold text-apple-text mb-2">{th(`${key}.title`)}</h3>
              <p class="text-[0.95rem] text-apple-muted font-medium leading-relaxed">{th(`${key}.body`)}</p>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a
            href={`/${lang}/mentores`}
            class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4"
          >
            {th('formation.cta')} <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Certifications & Academies -->
    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 pb-20 md:pb-32">
      <div class="bg-apple-surface-alt rounded-[2.5rem] p-6 sm:p-10 md:p-16 border border-apple-border">
        <div class="max-w-[900px] mb-14">
          <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-4">{th('academies.title')}</h2>
          <p class="text-[1.05rem] text-apple-muted font-medium leading-relaxed">{th('academies.subtitle')}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            { key: 'academies.cards.huawei', logo: '/logos/huawei.webp' },
            { key: 'academies.cards.cisco', logo: '/logos/cisco.webp' },
            { key: 'academies.cards.certifications' },
          ].map(({ key, logo }) => (
            <div class="bg-apple-surface rounded-2xl p-7 border border-apple-border shadow-sm hover:shadow-md transition-shadow">
              {logo ? (
                <img src={logo} alt={th(`${key}.title`)} class="h-9 w-auto object-contain mb-5" loading="lazy" />
              ) : (
                <div class="mb-5 inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[#eef2ff] text-[#355fb6]">
                  <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" aria-hidden="true">
                    <path d="M12 2 4 5v6c0 5 3.4 9.3 8 10 4.6-.7 8-5 8-10V5l-8-3Z" />
                    <path d="m9 12 2 2 4-4" />
                  </svg>
                </div>
              )}
              <h3 class="text-[1.05rem] font-bold text-apple-text mb-2">{th(`${key}.title`)}</h3>
              <p class="text-[0.92rem] text-apple-muted font-medium leading-relaxed">{th(`${key}.description`)}</p>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a
            href={`/${lang}/formacion`}
            class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4"
          >
            {th('academies.cta')} <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Outcomes -->
    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 pb-20 md:pb-32">
      <div class="rounded-[2rem] border border-apple-border bg-apple-surface p-8 md:p-10 shadow-sm">
        <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-8">{th('outcomes.title')}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { key: 'outcomes.items.apps' },
            { key: 'outcomes.items.networks' },
            { key: 'outcomes.items.databases' },
            { key: 'outcomes.items.iot' },
            { key: 'outcomes.items.security' },
            { key: 'outcomes.items.uiux' },
            { key: 'outcomes.items.projects' },
            { key: 'outcomes.items.entrepreneurship' },
          ].map(({ key }) => (
            <div class="rounded-2xl border border-apple-border bg-apple-surface-alt px-5 py-4 text-[0.98rem] font-semibold text-apple-text">
              {th(key)}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 pb-20 md:pb-32">
      <div class="mb-14">
        <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-4">{th('projects.title')}</h2>
        <p class="text-[1.15rem] text-apple-muted font-medium leading-relaxed max-w-[720px]">
          {th('projects.subtitle')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { key: 'projects.featured',   icon: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM12 8v4M12 16h.01' },
          { key: 'projects.guides',     icon: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z' },
          { key: 'projects.systems',    icon: 'M18 20V10M12 20V4M6 20v-6' },
          { key: 'projects.infra',      icon: 'M2 3h20M2 9h20M2 15h20M2 21h20' },
        ].map(({ key, icon }) => (
          <div class="bg-apple-surface-alt rounded-2xl p-8 border border-apple-border hover:shadow-[0_10px_30px_rgba(0,0,0,0.04)] hover:-translate-y-0.5 transition-all duration-300 group">
            <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2" fill="none" class="text-apple-muted mb-5 group-hover:text-apple-blue transition-colors">
              <path d={icon} />
            </svg>
            <h3 class="text-[1.05rem] font-bold text-apple-text mb-2">{th(`${key}.name`)}</h3>
            <p class="text-[0.9rem] text-apple-muted font-medium leading-relaxed">{th(`${key}.description`)}</p>
          </div>
        ))}
      </div>

      <div class="mt-10 flex gap-6">
        <a href="https://github.com/tics-itsoeh" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
          {th('projects.cta')} <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </section>

    <!-- Community -->
    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 pb-20 md:pb-32 border-t border-apple-border pt-14 md:pt-20">
      <div class="mb-14">
        <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-4">{th('mentors.title')}</h2>
        <p class="text-[1.15rem] text-apple-muted font-medium">{th('mentors.subtitle')}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { key: 'mentors.cards.clubs' },
          { key: 'mentors.cards.faculty' },
          { key: 'mentors.cards.students' },
        ].map(({ key }) => (
          <div class="bg-apple-surface-alt rounded-2xl p-8 border border-apple-border hover:shadow-[0_10px_30px_rgba(0,0,0,0.04)] hover:-translate-y-0.5 transition-all duration-300">
            <h3 class="text-[1.05rem] font-bold text-apple-text mb-2">{th(`${key}.title`)}</h3>
            <p class="text-[0.9rem] text-apple-muted font-medium leading-relaxed">{th(`${key}.description`)}</p>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <a href={`/${lang}/mentores`} class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
          {th('mentors.cta')}
        </a>
      </div>
    </section>

    <!-- Testimonials -->
    <Testimonials lang={lang} />

    <!-- Contact -->
    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 pb-20 md:pb-32 border-t border-apple-border pt-14 md:pt-20">
      <div class="bg-apple-surface-alt rounded-[2.5rem] p-6 sm:p-10 md:p-16 border border-apple-border">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
          <div>
            <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-4">{th('contact.title')}</h2>
            <p class="text-[1.05rem] text-apple-muted font-medium leading-relaxed max-w-[760px] mb-8">{th('contact.subtitle')}</p>

            <div class="rounded-2xl border border-apple-border bg-apple-surface p-6">
              <div class="space-y-4">
                <div>
                  <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-apple-muted mb-1">{tco('labels.institution')}</p>
                  <p class="text-[1rem] font-semibold text-apple-text leading-relaxed">{tco('values.institutionLine1')}</p>
                  <p class="text-[1rem] font-semibold text-apple-text leading-relaxed">{tco('values.institutionLine2')}</p>
                </div>
                <div>
                  <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-apple-muted mb-1">{tco('labels.location')}</p>
                  <p class="text-[0.98rem] text-apple-muted font-medium leading-relaxed">{tco('values.location')}</p>
                </div>
                <div>
                  <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-apple-muted mb-1">{tco('labels.phone')}</p>
                  <a href={phoneUrl} class="text-[1rem] font-semibold text-apple-text hover:text-apple-blue transition-colors">{tco('values.phone')}</a>
                </div>
                <div>
                  <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-apple-muted mb-1">{tco('labels.whatsapp')}</p>
                  <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="text-[1rem] font-semibold text-apple-text hover:text-apple-blue transition-colors">{tco('values.whatsapp')}</a>
                </div>
                <div>
                  <p class="text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-apple-muted mb-1">{tco('labels.email')}</p>
                  <a href={emailUrl} class="text-[1rem] font-semibold text-apple-text hover:text-apple-blue transition-colors">{tco('values.email')}</a>
                </div>
              </div>

              <div class="mt-6 flex flex-col sm:flex-row sm:flex-wrap gap-3">
                <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex w-full sm:w-auto items-center justify-center px-5 py-3 bg-apple-blue text-white rounded-full text-[0.95rem] font-semibold hover:bg-apple-blue-hover transition-colors">
                  {tco('actions.whatsapp')}
                </a>
                <a href={emailUrl} class="inline-flex w-full sm:w-auto items-center justify-center px-5 py-3 bg-apple-surface border border-apple-border-strong text-apple-text rounded-full text-[0.95rem] font-semibold hover:bg-apple-surface-hover transition-colors">
                  {tco('actions.email')}
                </a>
                <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="inline-flex w-full sm:w-auto items-center justify-center px-5 py-3 bg-apple-surface border border-apple-border-strong text-apple-text rounded-full text-[0.95rem] font-semibold hover:bg-apple-surface-hover transition-colors">
                  {tco('actions.instagram')}
                </a>
              </div>
            </div>
          </div>

          <div class="rounded-2xl border border-apple-border bg-apple-surface overflow-hidden min-h-[360px]">
            <iframe
              src={mapEmbedSrc}
              class="w-full h-full min-h-[360px]"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación del campus en Google Maps"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-[1200px] mx-auto px-5 sm:px-8 pb-20 md:pb-32 border-t border-apple-border pt-14 md:pt-20">
      <div class="rounded-[2rem] border border-apple-border bg-apple-surface-alt p-8 md:p-10">
        <h2 class="text-[clamp(1.9rem,3.4vw,2.6rem)] font-bold tracking-tight mb-8">{th('faq.title')}</h2>

        <div class="divide-y divide-black/8">
          {[
            { key: 'faq.items.programming' },
            { key: 'faq.items.math' },
            { key: 'faq.items.ai' },
            { key: 'faq.items.jobs' },
          ].map(({ key }) => (
            <article class="py-6 first:pt-0 last:pb-0">
              <h3 class="text-[1.08rem] font-semibold text-apple-text mb-2">{th(`${key}.question`)}</h3>
              <p class="text-[0.98rem] text-apple-muted font-medium leading-relaxed">{th(`${key}.answer`)}</p>
            </article>
          ))}
        </div>

        <div class="mt-10">
          <a href={`/${lang}/contacto`} class="inline-flex items-center gap-2 font-semibold text-apple-blue hover:underline hover:underline-offset-4">
            {th('faq.cta')} <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="max-w-[800px] mx-auto px-5 sm:px-8 text-center pb-20 md:pb-32 border-t border-apple-border pt-14 md:pt-20">
      <h2 class="text-[clamp(2rem,3.5vw,2.8rem)] font-bold tracking-tight mb-8">
        {th('finalCta.title')}
      </h2>
      <p class="text-[1.05rem] text-apple-muted font-medium leading-relaxed max-w-[760px] mx-auto mb-10">
        {th('finalCta.subtitle')}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`/${lang}/unirse`}
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-blue text-white text-[1rem] font-semibold rounded-full hover:bg-apple-blue-hover transition-all hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]"
        >
          {th('finalCta.primary')}
        </a>
        <a
          href={`/${lang}/contacto`}
          class="inline-flex w-full sm:w-auto items-center justify-center px-5 sm:px-8 py-4 bg-apple-surface border border-apple-border-strong text-apple-text text-[1rem] font-semibold rounded-full hover:bg-apple-surface-hover transition-colors"
        >
          {th('finalCta.secondary')}
        </a>
      </div>
    </section>

  </main>
</Layout>
