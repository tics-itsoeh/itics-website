---
import Layout from "../../../layouts/Layout.astro";
import type { UiLanguage } from "../../../i18n/config";
import { languages } from "../../../i18n/config";
import { useTranslations } from "../../../i18n/utils";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: UiLanguage };
const t = useTranslations(lang, "mentors");
const tc = useTranslations(lang, "common");
---

<Layout
  lang={lang}
  title={`${tc("nav.mentors")} · José Manuel Cortés Cerón`}
>
  <main class="bg-apple-bg pt-32 pb-24 min-h-screen">
    <div
      class="max-w-[1000px] mx-auto px-8 flex flex-col items-center lg:items-start"
    >
      <a
        href={`/${lang}/mentores`}
        class="inline-flex items-center gap-2 text-sm font-medium text-apple-muted hover:text-apple-text transition-colors mb-12 self-start lg:ml-[calc(50%-450px)]"
      >
        <span aria-hidden="true">&larr;</span>
        {lang === "es" ? "Volver a mentores" : "Back to mentors"}
      </a>

      <div
        class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-start justify-center w-full"
      >
        <!-- Sidebar: Photo + Links -->
        <div class="w-full max-w-[340px] mx-auto lg:mx-0 flex-shrink-0">
          <div
            class="aspect-[4/5] w-full overflow-hidden rounded-3xl bg-[#f5f5f7] mb-6 relative shadow-sm"
          >
            <img
              src="/mentors/josepo.png"
              alt="José Manuel Cortés Cerón"
              class="w-full h-full object-cover object-top"
              loading="lazy"
              decoding="async"
            />
            <div
              class="absolute inset-0 ring-1 ring-inset ring-black/5 rounded-3xl pointer-events-none"
            >
            </div>
          </div>
          <div class="flex flex-col gap-3 w-full">
            {
              [
                {
                  href: "https://github.com/deepdevjose",
                  label: "GitHub",
                  handle: "@deepdevjose",
                  icon: "M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22",
                },
                {
                  href: "https://www.linkedin.com/in/deepdevjose/",
                  label: "LinkedIn",
                  handle: "deepdevjose",
                  icon: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z M2 9h4v12H2z",
                },
                {
                  href: "https://deepdev-portfolio.vercel.app",
                  label: "Portfolio",
                  handle: "deepdev-portfolio",
                  icon: "M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z M2 12h20 M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z",
                },
                {
                  href: "https://www.instagram.com/deepdevjose/",
                  label: "Instagram",
                  handle: "@deepdevjose",
                  icon: "M2 2h20v20H2z M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z M17.5 6.5h.01",
                },
                {
                  href: "https://www.facebook.com/deepdevjose",
                  label: "Facebook",
                  handle: "/deepdevjose",
                  icon: "M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z",
                },
              ].map(({ href, label, handle, icon }) => (
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 px-4 py-3 bg-white rounded-xl border border-black/5 hover:border-apple-blue/50 hover:shadow-md transition-all shadow-sm group"
                >
                  <svg
                    viewBox="0 0 24 24"
                    width="20"
                    height="20"
                    stroke="currentColor"
                    stroke-width="2"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-apple-text group-hover:text-apple-blue transition-colors flex-shrink-0"
                  >
                    <path d={icon} />
                  </svg>
                  <div>
                    <p class="text-[0.65rem] font-bold tracking-wider uppercase text-apple-muted mb-0.5">
                      {label}
                    </p>
                    <p class="text-[0.9rem] font-bold text-apple-text leading-none group-hover:text-apple-blue transition-colors">
                      {handle}
                    </p>
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <!-- Main content -->
        <div class="flex-1 w-full max-w-[560px] mx-auto lg:mx-0 lg:pt-4">
          <h1
            class="text-4xl lg:text-5xl font-black tracking-tight text-apple-text mb-4 text-center lg:text-left"
          >
            José Manuel Cortés Cerón
          </h1>
          <p
            class="text-xl font-medium text-apple-muted mb-8 text-center lg:text-left"
          >
            {t("jose.role")}
          </p>

          <div
            class="flex items-center flex-wrap justify-center lg:justify-start gap-2 mb-12"
          >
            <span
              class="text-sm font-semibold px-4 py-1.5 bg-black/5 text-apple-text rounded-md tracking-wide"
              >Software</span
            >
            <span
              class="text-sm font-semibold px-4 py-1.5 bg-black/5 text-apple-text rounded-md tracking-wide"
              >IoT</span
            >
            <span
              class="text-sm font-semibold px-4 py-1.5 bg-black/5 text-apple-text rounded-md tracking-wide"
              >AI</span
            >
          </div>

          <div
            class="prose prose-lg prose-apple max-w-none mb-14 text-apple-text leading-relaxed"
          >
            <p class="mb-4">
              Me especializo en arquitectura de sistemas distribuidos,
              construyendo puentes altamente escalables entre el hardware (IoT)
              y la inteligencia artificial para crear soluciones tecnológicas
              eficientes e interactivas que resuelvan problemas fundamentales de
              la vida real.
            </p>
            <p>
              En la academia, mi filosofía es simple: <strong
                >ensuciarse las manos con código de producción real desde el día
                cero.</strong
              > Jamás enseñaré algoritmos que nunca usarás ni tutoriales desfasados;
              construimos pipelines de ingeniería y repositorios de software completos.
              Te enseñaré a modelar arquitecturas complejas, optimizar el uso de procesamiento
              en el cliente y estructurar lógica escalable para agentes o interfaces
              web puras.
            </p>
          </div>

          <div class="mb-16 border-t border-black/5 pt-8">
            <h2
              class="text-sm font-bold tracking-widest uppercase text-apple-muted mb-5"
            >
              {lang === "es" ? "Contexto Académico" : "Academic Background"}
            </h2>
            <div class="flex flex-col gap-4">
              <div class="flex items-start gap-4">
                <div
                  class="w-8 h-8 rounded-full bg-black/5 flex items-center justify-center flex-shrink-0 mt-0.5"
                >
                  <svg
                    class="text-apple-text"
                    viewBox="0 0 24 24"
                    width="14"
                    height="14"
                    stroke="currentColor"
                    stroke-width="2.5"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path
                      d="M6 12v5c3 3 9 3 12 0v-5"></path></svg
                  >
                </div>
                <div>
                  <p
                    class="text-[0.95rem] font-bold text-apple-text leading-tight mb-0.5"
                  >
                    Ingeniería en Tecnologías de la Información y Comunicaciones
                  </p>
                  <p class="text-[0.85rem] font-medium text-apple-muted">
                    Instituto Tecnológico Superior de Occidente del Estado de
                    Hidalgo
                  </p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div
                  class="w-8 h-8 rounded-full bg-black/5 flex items-center justify-center flex-shrink-0 mt-0.5"
                >
                  <svg
                    class="text-apple-text"
                    viewBox="0 0 24 24"
                    width="14"
                    height="14"
                    stroke="currentColor"
                    stroke-width="2.5"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><path
                      d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                    ></path></svg
                  >
                </div>
                <div>
                  <p
                    class="text-[0.95rem] font-bold text-apple-text leading-tight mb-0.5"
                  >
                    Research Collaboration
                  </p>
                  <p class="text-[0.85rem] font-medium text-apple-muted">
                    Xi'an Jiaotong–Liverpool University (西交利物浦大学)
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold tracking-tight text-apple-text mb-6">
              {
                lang === "es"
                  ? "Contribuciones recientes"
                  : "Recent contributions"
              }
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <a
                href="https://github.com/tics-itsoeh"
                target="_blank"
                class="flex flex-col h-full p-5 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-md hover:border-apple-blue/30 transition-all group"
              >
                <div class="flex items-center gap-2 mb-2">
                  <svg
                    class="text-apple-blue"
                    viewBox="0 0 24 24"
                    width="18"
                    height="18"
                    stroke="currentColor"
                    stroke-width="2"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path
                      d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"
                    ></path></svg
                  >
                  <h3
                    class="font-bold text-apple-text group-hover:text-apple-blue transition-colors"
                  >
                    Nexus
                  </h3>
                </div>
                <p
                  class="text-[0.92rem] font-medium text-apple-muted line-clamp-2 mt-auto"
                >
                  {
                    lang === "es"
                      ? "Formación fundacional de la academia y sistema interactivo nativo."
                      : "Foundational academy training system and native interactive experience."
                  }
                </p>
              </a>
              <a
                href="https://github.com/deepdevjose"
                target="_blank"
                class="flex flex-col h-full p-5 bg-white rounded-2xl border border-black/5 shadow-sm hover:shadow-md hover:border-apple-blue/30 transition-all group"
              >
                <div class="flex items-center gap-2 mb-2">
                  <svg
                    class="text-apple-blue flex-shrink-0"
                    viewBox="0 0 24 24"
                    width="18"
                    height="18"
                    stroke="currentColor"
                    stroke-width="2"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><rect x="2" y="3" width="20" height="14" rx="2" ry="2"
                    ></rect><line x1="8" y1="21" x2="16" y2="21"></line><line
                      x1="12"
                      y1="17"
                      x2="12"
                      y2="21"></line></svg
                  >
                  <h3
                    class="font-bold text-apple-text group-hover:text-apple-blue transition-colors truncate"
                  >
                    VLM Agent
                  </h3>
                </div>
                <p
                  class="text-[0.92rem] font-medium text-apple-muted line-clamp-2 mt-auto"
                >
                  {
                    lang === "es"
                      ? "Motor de inferencia WebGPU descentralizado y con cache inteligente."
                      : "Decentralized WebGPU inference engine with intelligent caching."
                  }
                </p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
