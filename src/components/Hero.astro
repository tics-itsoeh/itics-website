---
import Model3DCanvas from './Model3DCanvas.astro';
import type { UiLanguage } from '../i18n/config';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: UiLanguage;
}

const { lang } = Astro.props;
const th = useTranslations(lang, 'home');
---

<section class="min-h-screen flex flex-col lg:flex-row items-center relative overflow-hidden bg-apple-bg" id="hero">
  <div class="flex-1 px-8 lg:px-[8vw] z-10 max-w-full lg:max-w-[800px] pt-[98px]">
    <h1 class="max-w-[13ch] text-balance text-[clamp(3.15rem,5.85vw,5.4rem)] font-black leading-[1.05] tracking-[-0.04em] mb-6 font-sans text-apple-text">
      {th('hero.title')}
    </h1>

    <p class="text-[clamp(1.2rem,2vw,1.55rem)] text-apple-muted font-medium leading-[1.4] mb-9 max-w-[650px] font-sans tracking-tight">
      {th('hero.subtitle')}
    </p>

    <div class="flex items-center">
      <a href={`/${lang}/formacion`} class="inline-block px-8 py-4 bg-apple-blue text-white rounded-full text-[1rem] font-semibold transition-all duration-300 hover:bg-apple-blue-hover hover:scale-[1.02] shadow-[0_8px_20px_rgba(0,102,204,0.25)]">
        {th('hero.ctaPrimary')}
      </a>
    </div>
  </div>

  <Model3DCanvas />
</section>
