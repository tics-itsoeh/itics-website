    <script>
      const loaderSeenKey = 'itics-loader-seen';
      let lenis: { raf: (time: number) => void; destroy: () => void } | null = null;
      let lenisRafId: number | null = null;

      function destroySmoothScroll() {
        if (lenisRafId !== null) {
          window.cancelAnimationFrame(lenisRafId);
          lenisRafId = null;
        }
        if (lenis) {
          lenis.destroy();
          lenis = null;
        }
      }

      async function setupSmoothScroll() {
        if (lenis) return;
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        try {
          const { default: Lenis } = await import('lenis');
          const scrollContent = document.getElementById('page-scroll-content') as HTMLElement | null;
          lenis = new Lenis({
            wrapper: window,
            content: scrollContent ?? document.documentElement,
            duration: 1.1,
            smoothWheel: true,
            wheelMultiplier: 0.9,
            touchMultiplier: 1.05,
            easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            anchors: true,
          });

          const raf = (time: number) => {
            if (!lenis) return;
            lenis.raf(time);
            lenisRafId = window.requestAnimationFrame(raf);
          };

          lenisRafId = window.requestAnimationFrame(raf);
        } catch (error) {
          destroySmoothScroll();
          console.warn('Smooth scroll initialization failed, using native scroll.', error);
        }
      }

      function showSiteLoader() {
        const loader = document.getElementById('site-loader');
        if (!loader) return;
        loader.classList.remove('site-loader--hidden');
        document.body.classList.add('is-loading');
      }

      function hideSiteLoader() {
        const loader = document.getElementById('site-loader');
        if (!loader) return;
        loader.classList.add('site-loader--hidden');
        document.body.classList.remove('is-loading');
      }

      function hasSeenLoader() {
        try {
          return window.sessionStorage.getItem(loaderSeenKey) === '1';
        } catch {
          return false;
        }
      }

      function markLoaderSeen() {
        try {
          window.sessionStorage.setItem(loaderSeenKey, '1');
        } catch {
          // Ignore storage access errors and continue gracefully.
        }
      }

      function setupNav() {
        const container = document.getElementById('nav-container');
        const pill = document.getElementById('nav-pill');
        const links = document.querySelectorAll('.nav-link');

        if (!container || !pill || links.length === 0) return;

        let activeLink = document.querySelector('.active-nav-item') as HTMLElement;

        function movePill(el: HTMLElement) {
          if (!pill) return;
          pill.style.opacity = '1';
          pill.style.width = `${el.offsetWidth}px`;
          pill.style.transform = `translateX(${el.offsetLeft}px)`;
        }

        if (activeLink) movePill(activeLink);

        links.forEach(link => {
          link.addEventListener('mouseenter', (e) => movePill(e.target as HTMLElement));
        });

        container.addEventListener('mouseleave', () => {
          if (activeLink) movePill(activeLink);
          else pill.style.opacity = '0';
        });
      }

      function setupMobileMenu() {
        const toggle = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        if (!toggle || !menu) return;
        if (toggle.getAttribute('data-menu-bound') === 'true') return;

        const closeMenu = () => {
          menu.classList.add('hidden');
          toggle.setAttribute('aria-expanded', 'false');
        };

        const toggleMenu = () => {
          const isOpen = !menu.classList.contains('hidden');
          if (isOpen) closeMenu();
          else {
            menu.classList.remove('hidden');
            toggle.setAttribute('aria-expanded', 'true');
          }
        };

        toggle.addEventListener('click', (event) => {
          event.stopPropagation();
          toggleMenu();
        });

        menu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeMenu);
        });

        toggle.setAttribute('data-menu-bound', 'true');
      }

      setupNav();
      setupMobileMenu();
      setupSmoothScroll();
      document.addEventListener('astro:page-load', setupNav);
      document.addEventListener('astro:page-load', setupMobileMenu);
      document.addEventListener('astro:page-load', setupSmoothScroll);
      document.addEventListener('astro:before-preparation', destroySmoothScroll);

      if (!hasSeenLoader()) {
        markLoaderSeen();
        showSiteLoader();
        const finishFirstLoadAnimation = () => hideSiteLoader();
        document.addEventListener('astro:page-load', finishFirstLoadAnimation, { once: true });
        window.addEventListener('load', finishFirstLoadAnimation, { once: true });
        window.setTimeout(finishFirstLoadAnimation, 2600);
      } else {
        hideSiteLoader();
      }

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch((err) => {
            console.warn('Service worker registration failed:', err);
          });
        });
      }
    </script>
